<!-- Admin Navbar  -->
<div class="top-strip" id="topStrip">
  <div class="top-strip-left">
    <!-- Ashoka Chakra-inspired emblem (SVG) -->
    <svg class="emblem" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"
      style="width:20px;height:20px;fill:var(--accent)">
      <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.5" />
      <circle cx="12" cy="12" r="3" fill="currentColor" />
      <line x1="12" y1="2" x2="12" y2="7" stroke="currentColor" stroke-width="1.2" />
      <line x1="12" y1="17" x2="12" y2="22" stroke="currentColor" stroke-width="1.2" />
      <line x1="2" y1="12" x2="7" y2="12" stroke="currentColor" stroke-width="1.2" />
      <line x1="17" y1="12" x2="22" y2="12" stroke="currentColor" stroke-width="1.2" />
      <line x1="4.93" y1="4.93" x2="8.46" y2="8.46" stroke="currentColor" stroke-width="1.2" />
      <line x1="15.54" y1="15.54" x2="19.07" y2="19.07" stroke="currentColor" stroke-width="1.2" />
      <line x1="19.07" y1="4.93" x2="15.54" y2="8.46" stroke="currentColor" stroke-width="1.2" />
      <line x1="8.46" y1="15.54" x2="4.93" y2="19.07" stroke="currentColor" stroke-width="1.2" />
    </svg>
    <span class="strip-text">Government of India &mdash; Digital Citizen Services Portal</span>
  </div>

  <div class="top-strip-right">
    <a href="/accessibility" style="font-size:0.75rem">Accessibility</a>
    <span class="lang-divider">|</span>
    <button type="button" data-lang-switch="en" onclick="window.switchLanguage && window.switchLanguage('en')"
      style="font-weight:700;color:var(--accent)">EN</button>
    <span class="lang-divider">/</span>
    <button type="button" data-lang-switch="hi"
      onclick="window.switchLanguage && window.switchLanguage('hi')">&#2361;&#2367;</button>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════
     MAIN HEADER — Brand + Login + e-Services
════════════════════════════════════════════════════════ -->
<header class="main-header" id="mainHeader">
  <div class="main-header-inner">
    <!-- Brand -->
    <a href="/" class="header-brand" aria-label="NIRVAAH Home">
      <div class="header-logo-wrap">
        <!-- Scale/balance icon representing civic justice -->
        <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" style="width:26px;height:26px">
          <path d="M12 3v18M5 7l7-4 7 4M5 7l3 8a4 4 0 0 0 8 0l3-8M3 20h18" stroke-linecap="round"
            stroke-linejoin="round" />
        </svg>
      </div>
      <div class="header-title-group">
        <span class="header-title">
          <%= __('appName') || 'NIRVAAH' %>
        </span>
        <span class="header-subtitle">Citizen Issue Reporting System</span>
      </div>
    </a>

    <!-- Right-side CTA buttons -->
    <div class="header-actions">
      <div class="nav-user" style="margin-left: 1.5rem;">
        <div class="nav-avatar" id="navAvatar" style="background:linear-gradient(135deg,#ef4444,#f59e0b)">A</div>
        <button class="btn btn-danger btn-sm" onclick="window.NIRVAAH.Auth.logout()" data-i18n="logout">
          <%= __('logout') %>
        </button>
      </div>
    </div>
  </div>
</header>