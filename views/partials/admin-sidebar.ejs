<!-- ADMIN SIDEBAR -->
<div class="admin-sidebar" id="adminSidebar">
  <div class="admin-sidebar-brand">
    <div class="admin-sidebar-badge">N</div>
    <div>
      <div class="admin-sidebar-title">NIRVAAH Admin</div>
    </div>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-label" data-i18n="sidebarOverview">
      <%= __('sidebarOverview') %>
    </div>
    <ul class="sidebar-menu">
      <li>
        <a
          href="/admin/dashboard"
          class="<%= navPage==='admin-dash'?'active':'' %>"
        >
          <span><%= __('sidebarDashboard') %></span>
        </a>
      </li>
      <li>
        <a
          href="/admin/analytics"
          class="<%= navPage==='admin-analytics'?'active':'' %>"
        >
          <span><%= __('sidebarAnalytics') %></span>
        </a>
