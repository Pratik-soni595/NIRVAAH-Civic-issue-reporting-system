<!-- ADMIN SIDEBAR -->
<div class="admin-sidebar" id="adminSidebar">
  <div
    class="admin-sidebar-brand"
    style="
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
    "
  >
    <div style="display: flex; align-items: center; gap: 0.75rem">
      <div class="admin-sidebar-badge">N</div>
      <div class="admin-sidebar-title">NIRVAAH Admin</div>
    </div>
    <button
      class="nav-toggle admin-close-toggle"
      onclick="document.getElementById('adminSidebar').classList.remove('open')"
      aria-label="Close Navigation"
      style="color: var(--text); padding: 0.25rem"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
      >
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-label" data-i18n="sidebarOverview">
      <%= __('sidebarOverview') %>
    </div>
    <ul class="sidebar-menu">
      <li>
        <a
          href="/admin/dashboard"
          class="<%= navPage==='admin-dash'?'active':'' %>"
        >
          <span><%= __('sidebarDashboard') %></span>
        </a>
      </li>
      <li>
        <a
          href="/admin/analytics"
          class="<%= navPage==='admin-analytics'?'active':'' %>"
        >
          <span><%= __('sidebarAnalytics') %></span>
        </a>
      </li>
    </ul>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-label" data-i18n="sidebarManagement">
      <%= __('sidebarManagement') %>
    </div>
    <ul class="sidebar-menu">
      <li>
        <a
          href="/admin/complaints"
          class="<%= navPage==='admin-complaints'?'active':'' %>"
        >
          <span><%= __('sidebarAllComplaints') %></span>
        </a>
      </li>
    </ul>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-label" data-i18n="sidebarTools">
      <%= __('sidebarTools') %>
    </div>
    <ul class="sidebar-menu">
      <li>
        <a href="/admin/map" class="<%= navPage==='admin-map'?'active':'' %>">
          <span><%= __('sidebarLiveMap') %></span>
        </a>
      </li>
      <li>
        <a
          href="/admin/leaderboard"
          class="<%= navPage==='admin-leaderboard'?'active':'' %>"
        >
          <span><%= __('sidebarLeaderboard') %></span>
        </a>
      </li>
    </ul>
  </div>
</div>
