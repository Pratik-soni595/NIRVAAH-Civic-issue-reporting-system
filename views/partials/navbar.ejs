<!-- ═══════════════════════════════════════════════════════
     OFFLINE BANNER
════════════════════════════════════════════════════════ -->
<div class="offline-banner" id="offlineBanner">
    <%- __('offlineBanner') %>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
            style="flex-shrink:0">
            <path
                d="M1 1l22 22M16.72 11.06A10.94 10.94 0 0 1 19 12.55M5 12.55a10.94 10.94 0 0 1 5.17-2.39M10.71 5.05A16 16 0 0 1 22.56 9M1.42 9a15.91 15.91 0 0 1 4.7-2.88M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01" />
        </svg>
        &nbsp;You are offline — <strong id="queueCount">0</strong> report(s) queued locally. Will sync on reconnection.
</div>

<!-- ═══════════════════════════════════════════════════════
     TOP STRIP — Government identifier bar
════════════════════════════════════════════════════════ -->
<div class="top-strip" id="topStrip">
    <div class="top-strip-left">
        <!-- Ashoka Chakra-inspired emblem (SVG) -->
        <svg class="emblem" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"
            style="width:20px;height:20px;fill:var(--accent)">
            <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.5" />
            <circle cx="12" cy="12" r="3" fill="currentColor" />
            <line x1="12" y1="2" x2="12" y2="7" stroke="currentColor" stroke-width="1.2" />
            <line x1="12" y1="17" x2="12" y2="22" stroke="currentColor" stroke-width="1.2" />
            <line x1="2" y1="12" x2="7" y2="12" stroke="currentColor" stroke-width="1.2" />
            <line x1="17" y1="12" x2="22" y2="12" stroke="currentColor" stroke-width="1.2" />
            <line x1="4.93" y1="4.93" x2="8.46" y2="8.46" stroke="currentColor" stroke-width="1.2" />
            <line x1="15.54" y1="15.54" x2="19.07" y2="19.07" stroke="currentColor" stroke-width="1.2" />
            <line x1="19.07" y1="4.93" x2="15.54" y2="8.46" stroke="currentColor" stroke-width="1.2" />
            <line x1="8.46" y1="15.54" x2="4.93" y2="19.07" stroke="currentColor" stroke-width="1.2" />
        </svg>
        <span class="strip-text">Government of India &mdash; Digital Citizen Services Portal</span>
    </div>

    <div class="top-strip-right">
        <% if (typeof navPage==='undefined' ) { %>
            <a href="#main-content" class="skip-link">Skip to Content</a>
            <span class="lang-divider">|</span>
            <% } %>
                <button type="button" data-lang-switch="en"
                    onclick="window.switchLanguage && window.switchLanguage('en')"
                    style="font-weight:700;color:var(--accent)">EN</button>
                <span class="lang-divider">/</span>
                <button type="button" data-lang-switch="hi"
                    onclick="window.switchLanguage && window.switchLanguage('hi')">&#2361;&#2367;</button>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════
     MAIN HEADER — Brand + Login + e-Services
════════════════════════════════════════════════════════ -->
<header class="main-header" id="mainHeader">
    <div class="main-header-inner">
        <!-- Brand -->
        <a href="/" class="header-brand" aria-label="NIRVAAH Home">
            <div class="header-logo-wrap">
                <!-- Scale/balance icon representing civic justice -->
                <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" style="width:26px;height:26px">
                    <path d="M12 3v18M5 7l7-4 7 4M5 7l3 8a4 4 0 0 0 8 0l3-8M3 20h18" stroke-linecap="round"
                        stroke-linejoin="round" />
                </svg>
            </div>
            <div class="header-title-group">
                <span class="header-title">
                    <%= __('appName') || 'NIRVAAH' %>
                </span>
                <span class="header-subtitle">Citizen Issue Reporting System</span>
            </div>
        </a>

        <!-- Right-side CTA buttons -->
        <div class="header-actions">
            <% if (typeof navPage !=='undefined' ) { %>
                <!-- Logged-in user: show profile link -->
                <a href="/profile" class="btn btn-outline btn-sm">My Profile</a>
                <a href="/report" class="btn btn-accent btn-sm">Report Issue</a>
                <% } else { %>
                    <a href="/login" class="btn btn-outline btn-sm" id="headerLoginBtn">
                        <%= __('login') || 'Login' %>
                    </a>
                    <a href="/register" class="btn btn-accent btn-sm" id="headerEservicesBtn">Register</a>
                    <% } %>
        </div>
    </div>
</header>

<!-- ═══════════════════════════════════════════════════════
     NAVIGATION BAR — Primary nav links
════════════════════════════════════════════════════════ -->
<nav class="navbar" id="mainNavbar" aria-label="Primary navigation">
    <div class="navbar-inner">
        <ul class="nav-links" id="navLinks">
            <% if (typeof navPage !=='undefined' ) { %>
                <!-- Authenticated user nav -->
                <li>
                    <a href="/" class="<%= navPage==='home'?'active':'' %>">
                        <span class="nav-icon">&#9632;</span> Home
                    </a>
                </li>
                <li>
                    <a href="/dashboard" class="<%= navPage==='dashboard'?'active':'' %>">
                        <span class="nav-icon">&#9632;</span>
                        <%= __('dashboard') %>
                    </a>
                </li>
                <li>
                    <a href="/report" class="<%= navPage==='report'?'active':'' %>">
                        <span class="nav-icon">&#9632;</span>
                        <%= __('reportIssue') %>
                    </a>
                </li>
                <li>
                    <a href="/my-complaints" class="<%= navPage==='mycomplaints'?'active':'' %>">
                        <span class="nav-icon">&#9632;</span> Track
                    </a>
                </li>
                <li>
                    <a href="/nearby" class="<%= navPage==='nearby'?'active':'' %>">
                        <span class="nav-icon">&#9632;</span>
                        <%= __('nearbyTitle') %>
                    </a>
                </li>
                <li>
                    <a href="/map" class="<%= navPage==='map'?'active':'' %>">
                        <span class="nav-icon">&#9632;</span>
                        <%= __('map') %>
                    </a>
                </li>
                <li>
                    <a href="/leaderboard" class="<%= navPage==='leaderboard'?'active':'' %>">
                        <span class="nav-icon">&#9632;</span>
                        <%= __('leaderboard') %>
                    </a>
                </li>
                <% } else { %>
                    <!-- Public user nav -->
                    <li><a href="/" class="active"><span class="nav-icon">&#9632;</span> Home</a></li>
                    <li><a href="/#about"><span class="nav-icon">&#9632;</span> About</a></li>
                    <li><a href="/admin/login"><span class="nav-icon">&#9632;</span> Admin</a></li>
                    <li><a href="/#contact"><span class="nav-icon">&#9632;</span> Contact</a></li>
                    <% } %>
        </ul>

        <!-- Authenticated user extras -->
        <% if (typeof navPage !=='undefined' ) { %>
            <div class="nav-user">
                <a href="/notifications" aria-label="Notifications"
                    style="position:relative;color:rgba(255,248,236,.82);font-size:1.1rem;padding:0.25rem;line-height:1">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                    </svg>
                    <span class="notif-dot hidden" id="notifDot"></span>
                </a>
                <div class="nav-avatar" id="navAvatar" onclick="toggleNavDropdown()">?</div>
                <div id="navDropdown" class="hidden"
                    style="position:absolute;top:52px;right:1.25rem;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:0.5rem;min-width:180px;box-shadow:var(--shadow-card);z-index:2000">
                    <a href="/profile"
                        style="display:block;padding:0.6rem 1rem;border-radius:var(--radius-sm);color:var(--text-muted);font-size:0.87rem"
                        data-i18n="profile">
                        <%= __('profile') %>
                    </a>
                    <div class="divider" style="margin:0.25rem 0"></div>
                    <a href="#" onclick="window.NIRVAAH.Auth.logout()"
                        style="display:block;padding:0.6rem 1rem;border-radius:var(--radius-sm);color:var(--danger);font-size:0.87rem"
                        data-i18n="logout">
                        <%= __('logout') %>
                    </a>
                </div>
            </div>
            <% } %>

                <button class="nav-toggle" onclick="document.getElementById('navLinks').classList.toggle('open')"
                    aria-label="Toggle navigation">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2.5">
                        <line x1="3" y1="6" x2="21" y2="6" />
                        <line x1="3" y1="12" x2="21" y2="12" />
                        <line x1="3" y1="18" x2="21" y2="18" />
                    </svg>
                </button>
    </div>
</nav>