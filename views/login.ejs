<%- include('partials/head') %>
<div class="auth-page">
  <div class="auth-orb auth-orb-1"></div>
  <div class="auth-orb auth-orb-2"></div>

  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo-icon" style="display:inline-flex;align-items:center;justify-content:center;">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8"><path d="M12 3v18M5 7l7-4 7 4M5 7l3 8a4 4 0 0 0 8 0l3-8M3 20h18" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <h1 class="auth-title" data-i18n="welcomeBack"><%= __('welcomeBack') %></h1>
      <p class="auth-subtitle" data-i18n="signInSub"><%= __('signInSub') %></p>
    </div>

    <form id="loginForm" novalidate>
      <div class="form-group">
        <label class="form-label" data-i18n="emailAddress"><%= __('emailAddress') %></label>
        <input type="email" class="form-control" id="email" data-i18n-placeholder="emailPlaceholder" placeholder="<%= __('emailPlaceholder') %>" required autocomplete="email">
      </div>
      <div class="form-group">
        <label class="form-label" style="display:flex;justify-content:space-between">
          <%= __('passwordLabel') %> <span style="font-weight:400;font-size:0.8rem;text-transform:none;letter-spacing:normal" data-i18n="forgotPassword"><%= __('forgotPassword') %></span>
        </label>
        <div style="position:relative">
          <input type="password" class="form-control" id="password" placeholder="••••••••" required autocomplete="current-password">
          <button type="button" id="togglePwd" class="toggle-pwd" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted);cursor:pointer;line-height:1;padding:0.2rem;transition: opacity 0.2s;" aria-label="Show password">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
          </button>
        </div>
      </div>

      <!-- OTP Section (hidden initially) -->
      <div class="form-group hidden" id="otpSection">
        <label class="form-label">Enter OTP</label>
        <input type="text" class="form-control" id="otp" placeholder="Enter 4-digit OTP" maxlength="4" required>
      </div>

      <div class="form-group" style="display:flex;align-items:center;gap:0.5rem">
        <input type="checkbox" id="termsAgree" style="accent-color:var(--primary);width:16px;height:16px">
        <label for="termsAgree" class="text-sm" style="text-transform:none;letter-spacing:normal;font-weight:400;color:var(--text-muted)">
          I agree to the <a href="/terms" style="color:var(--primary);text-decoration:underline;">Terms and Conditions</a>
        </label>
      </div>

      <div class="text-danger text-sm mb-2 hidden text-center" id="loginError"></div>
      <div class="text-success text-sm mb-2 hidden text-center" id="loginMessage"></div>

      <!-- Initial login button -->
      <button type="button" class="btn btn-primary btn-lg btn-block" id="sendOtpBtn">
        <span id="sendOtpBtnText">Send OTP</span>
      </button>

      <!-- OTP verification buttons (hidden initially) -->
      <div class="hidden" id="otpButtons">
        <button type="button" class="btn btn-primary btn-lg btn-block" id="verifyOtpBtn">
          <span id="verifyOtpBtnText">Verify OTP</span>
        </button>
        <button type="button" class="btn btn-outline btn-lg btn-block mt-2" id="resendOtpBtn">
          <span id="resendOtpBtnText">Resend OTP</span>
        </button>
      </div>
    </form>

    <div class="divider"></div>



    <p class="text-center text-sm text-muted">
      <%= __('noAccountQ') %> <a href="/register" class="text-primary fw-bold" data-i18n="createOneFree"><%= __('createOneFree') %></a>
    </p>
  </div>
</div>

<div class="toast-container" id="toastContainer"></div>
<script src="/js/api.js"></script>
<script>
if (window.NIRVAAH?.Auth.isLoggedIn()) {
  const u = window.NIRVAAH.getUser();
  window.location.href = (u?.accountType === 'admin' || u?.role === 'admin') ? '/admin/dashboard' : '/dashboard';
}

document.querySelectorAll('.toggle-pwd').forEach(btn => {
  btn.addEventListener('click', function() {
    const input = this.previousElementSibling;
    const isPassword = input.type === 'password';
    input.type = isPassword ? 'text' : 'password';
    this.innerHTML = isPassword ? 
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>' :
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';
    this.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
  });
});

document.getElementById('termsAgree').addEventListener('change', function() {
  document.getElementById('sendOtpBtn').disabled = !this.checked;
});

// Initially disable Send OTP button
document.getElementById('sendOtpBtn').disabled = true;

let currentSessionId = null;

document.getElementById('sendOtpBtn').addEventListener('click', async () => {
  const errEl = document.getElementById('loginError');
  const msgEl = document.getElementById('loginMessage');
  errEl.classList.add('hidden');
  msgEl.classList.add('hidden');

  if (!document.getElementById('termsAgree').checked) {
    errEl.textContent = 'You must agree to the Terms and Conditions to sign in.';
    errEl.classList.remove('hidden');
    return;
  }

  const email = document.getElementById('email').value.trim();
  const password = document.getElementById('password').value;

  if (!email || !password) {
    errEl.textContent = 'Please enter email and password.';
    errEl.classList.remove('hidden');
    return;
  }

  const btn = document.getElementById('sendOtpBtn');
  const txt = document.getElementById('sendOtpBtnText');
  btn.disabled = true;
  txt.textContent = 'Sending OTP...';

  try {
    const data = await window.NIRVAAH.Auth.sendOtp(email, password);
    currentSessionId = data.sessionId;
    txt.textContent = 'OTP Sent!';
    msgEl.textContent = 'OTP sent successfully. Check the console for the code.';
    msgEl.classList.remove('hidden');

    // Show OTP section
    document.getElementById('otpSection').classList.remove('hidden');
    document.getElementById('otpButtons').classList.remove('hidden');
    document.getElementById('sendOtpBtn').classList.add('hidden');

    // Focus on OTP input
    document.getElementById('otp').focus();
  } catch (err) {
    errEl.textContent = err.message || 'Failed to send OTP';
    errEl.classList.remove('hidden');
    btn.disabled = false;
    txt.textContent = 'Send OTP';
  }
});

document.getElementById('verifyOtpBtn').addEventListener('click', async () => {
  const errEl = document.getElementById('loginError');
  const msgEl = document.getElementById('loginMessage');
  errEl.classList.add('hidden');
  msgEl.classList.add('hidden');

  if (!currentSessionId) {
    errEl.textContent = 'No OTP session. Please send OTP first.';
    errEl.classList.remove('hidden');
    return;
  }

  const otpValue = document.getElementById('otp').value.trim();
  if (!otpValue || otpValue.length !== 4) {
    errEl.textContent = 'Please enter a valid 4-digit OTP.';
    errEl.classList.remove('hidden');
    return;
  }

  const btn = document.getElementById('verifyOtpBtn');
  const txt = document.getElementById('verifyOtpBtnText');
  btn.disabled = true;
  txt.textContent = 'Verifying...';

  try {
    const data = await window.NIRVAAH.Auth.verifyOtp(currentSessionId, otpValue);
    txt.textContent = 'Verified!';
    msgEl.textContent = 'OTP verified successfully. Redirecting...';
    msgEl.classList.remove('hidden');

    setTimeout(() => {
      window.location.href = (data.accountType === 'admin' || data.user.role === 'admin') ? '/admin/dashboard' : '/dashboard';
    }, 1000);
  } catch (err) {
    if (err.data && err.data.expired) {
      errEl.textContent = 'OTP expired. Please request a new code.';
    } else {
      errEl.textContent = err.message || 'OTP verification failed';
    }
    errEl.classList.remove('hidden');
    btn.disabled = false;
    txt.textContent = 'Verify OTP';
  }
});

document.getElementById('resendOtpBtn').addEventListener('click', async () => {
  const errEl = document.getElementById('loginError');
  const msgEl = document.getElementById('loginMessage');
  errEl.classList.add('hidden');
  msgEl.classList.add('hidden');

  if (!currentSessionId) {
    errEl.textContent = 'No OTP session. Please send OTP first.';
    errEl.classList.remove('hidden');
    return;
  }

  const btn = document.getElementById('resendOtpBtn');
  const txt = document.getElementById('resendOtpBtnText');
  btn.disabled = true;
  txt.textContent = 'Resending...';

  try {
    const data = await window.NIRVAAH.Auth.resendOtp(currentSessionId);
    currentSessionId = data.sessionId;
    txt.textContent = 'Resent!';
    msgEl.textContent = 'New OTP sent. Check the console for the code.';
    msgEl.classList.remove('hidden');

    // Clear OTP input
    document.getElementById('otp').value = '';
    document.getElementById('otp').focus();
  } catch (err) {
    errEl.textContent = err.message || 'Failed to resend OTP';
    errEl.classList.remove('hidden');
    btn.disabled = false;
    txt.textContent = 'Resend OTP';
  }
});
</script>
</body></html>
