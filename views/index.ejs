        <style>
            .impact-slider-section {
                padding: 4.5rem 0 2rem 0;
                background: #FFFFFF;
                text-align: center;
            }

            .impact-slider-section .section-title {
                font-size: 2.5rem;
                font-weight: 800;
                color: #1a1a1a;
                margin-bottom: 0.5rem;
            }

            .impact-slider-section .section-subtitle {
                font-size: 1.1rem;
                color: var(--text-muted);
                margin-bottom: 2.5rem;
            }

            .slider-wrapper {
                position: relative;
                width: 100%;
                max-width: 800px;
                margin: 0 auto;
                border-radius: 12px;
                overflow: hidden;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
                aspect-ratio: 16 / 9;
            }

            .slider-img {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                pointer-events: none;
            }

            .slider-img.img-before {
                clip-path: polygon(0 0, 50% 0, 50% 100%, 0 100%);
                z-index: 2;
            }

            .slider-handle {
                position: absolute;
                top: 0;
                left: 50%;
                width: 4px;
                height: 100%;
                background: #fff;
                cursor: ew-resize;
                transform: translateX(-50%);
                z-index: 10;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .slider-button {
                width: 40px;
                height: 40px;
                background: var(--primary, #1155cc);
                border-radius: 50%;
                color: #fff;
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
            }

            .slider-badge {
                position: absolute;
                top: 20px;
                padding: 6px 16px;
                border-radius: 20px;
                color: #fff;
                font-weight: 600;
                font-size: 0.9rem;
                z-index: 15;
            }

            .badge-before {
                left: 20px;
                background: #ef4444;
            }

            .badge-after {
                right: 20px;
                background: #10b981;
            }

            @media (max-width: 768px) {
                .slider-wrapper {
                    aspect-ratio: 4/3;
                    border-radius: 8px;
                }

                .impact-slider-section .section-title {
                    font-size: 2rem;
                }
            }
        </style>

        <!-- ═══════════════════════════════════════════════════════
     IMPACT SLIDER SECTION
════════════════════════════════════════════════════════ -->
        <section class="impact-slider-section" id="impact-slider">
            <div class="container">
                <h2 class="section-title">Real Impact, Real Change</h2>
                <p class="section-subtitle">Drag the slider to see the transformation</p>

                <div class="slider-wrapper" id="beforeAfterSlider">
                    <!-- Base Image (After) -->
                    <img src="/images/after_road.png" alt="After Repair" class="slider-img img-after" />

                    <!-- Top Image (Before) -->
                    <img src="/images/before_pothole.png" alt="Before Repair" class="slider-img img-before"
                        id="imgBefore" />

                    <!-- Slider Handle -->
                    <div class="slider-handle" id="sliderHandle">
                        <div class="slider-button">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 18 3 12 9 6"></polyline>
                                <polyline points="15 6 21 12 15 18"></polyline>
                            </svg>
                        </div>
                    </div>

                    <!-- Badges -->
                    <div class="slider-badge badge-before">Before</div>
                    <div class="slider-badge badge-after">After</div>
                </div>
            </div>
        </section>

