     HERO SECTION
════════════════════════════════════════════════════════   -->
        <main class="hero-section" id="main-content">
            <div class="container">
                <div class="hero-content">

                    <!-- Official badge -->
                    <div class="hero-badge" data-i18n="heroBadge">
                        Official Civic Platform
                    </div>

                    <!-- Main heading -->
                    <h1 class="hero-title" data-i18n="heroTitle">
                        Empowering Citizens for<br>Better Governance
                    </h1>

                    <!-- Subtext -->
                    <p class="hero-subtitle" data-i18n="heroSubtitle">
                        Report public infrastructure issues &mdash; roads, water, electricity, sanitation &mdash;
                        and track real-time resolution status.
                    </p>

