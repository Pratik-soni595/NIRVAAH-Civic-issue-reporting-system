<%- include('partials/head') %>
  <%- include('partials/navbar', {navPage}) %>

    <div class="page-wrapper">
      <div class="container" style="padding-top:2rem;padding-bottom:3rem;max-width:720px">

        <!-- PAGE HEADER -->
        <div class="breadcrumb mb-2">
          <a href="/" data-i18n="home">Home</a>
          <span>›</span>
          <span data-i18n="communityLeaderboard"><%- __('communityLeaderboard') %></span>
        </div>

        <div style="margin-bottom:2rem">
          <h1 class="section-title" style="font-size:1.75rem;padding-bottom:.5rem" data-i18n="communityLeaderboard"><%-
              __('communityLeaderboard') %></h1>
          <p class="text-muted" data-i18n="lbSubtitle">
            <%= __('lbSubtitle') %>
          </p>
        </div>

        <!-- POINTS SYSTEM -->
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:2rem">
          <div
            style="background:var(--bg-card);border:1px solid var(--border);border-top:3px solid var(--primary);border-radius:var(--radius-sm);padding:1rem;text-align:center">
            <div style="font-size:1.5rem;font-weight:700;color:var(--primary-dark);font-family:'Merriweather',serif">+10
            </div>
            <div
              style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);margin-top:.2rem"
              data-i18n="perComplaint">
              <%= __('perComplaint') %>
            </div>
          </div>
          <div
            style="background:var(--bg-card);border:1px solid var(--border);border-top:3px solid var(--accent);border-radius:var(--radius-sm);padding:1rem;text-align:center">
            <div style="font-size:1.5rem;font-weight:700;color:var(--primary-dark);font-family:'Merriweather',serif">+2
            </div>
            <div
              style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);margin-top:.2rem"
              data-i18n="perVote">
              <%= __('perVote') %>
            </div>
          </div>
          <div
            style="background:var(--bg-card);border:1px solid var(--border);border-top:3px solid var(--resolved);border-radius:var(--radius-sm);padding:1rem;text-align:center">
            <div style="font-size:1.5rem;font-weight:700;color:var(--primary-dark);font-family:'Merriweather',serif">+25
            </div>
            <div
              style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);margin-top:.2rem"
              data-i18n="onResolved">
              <%= __('onResolved') %>
            </div>
          </div>
        </div>

        <!-- SECTION LABEL -->
        <div class="section-header" style="margin-bottom:1rem">
          <h2 class="section-title" style="font-size:1rem;padding-bottom:.35rem;letter-spacing:.04em">Top Contributors
          </h2>
        </div>

        <!-- LEADERBOARD LIST -->
        <div id="list">
          <div class="loading-center">
            <div class="spinner"></div>
          </div>
        </div>

      </div>
    </div>

    <%- include('partials/scripts') %>
      <script>
        const medals = ['1st', '2nd', '3rd'];

        async function loadLeaderboard() {
          try {
            const data = await window.NIRVAAH.Users.getLeaderboard();
            const leaders = data.leaderboard || [];
            const me = window.NIRVAAH?.getUser();

            if (!leaders.length) {
              document.getElementById('list').innerHTML = `
        <div class="empty-state" style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:4rem 2rem">
          <div class="empty-title" data-i18n="noDataYet"><%= __('noDataYet') %></div>
        </div>`;
              return;
            }

            document.getElementById('list').innerHTML = leaders.map((u, i) => {
              const isMe = me && u._id === me.id;
              const isTop3 = i < 3;
              const rankColors = ['#b48a3c', '#8a9ba8', '#a0604a'];
              const rankColor = isTop3 ? rankColors[i] : 'var(--text-muted)';

              return `
        <div style="
          display:flex;align-items:center;gap:1rem;
          padding:1rem 1.25rem;
          background:var(--bg-card);
          border:1px solid ${isMe ? 'var(--primary)' : 'var(--border)'};
          border-left:4px solid ${isTop3 ? rankColor : 'var(--border)'};
          border-radius:var(--radius-sm);
          margin-bottom:.65rem;
          transition:all .2s ease;
        "
        onmouseover="this.style.boxShadow='var(--shadow-card)'"
        onmouseout="this.style.boxShadow=''">

          <!-- RANK -->
          <div style="min-width:44px;text-align:center;font-weight:700;font-size:.88rem;color:${rankColor}">
            ${isTop3 ? medals[i] : '#' + (i + 1)}
          </div>

          <!-- AVATAR -->
          <div style="
            width:42px;height:42px;border-radius:50%;flex-shrink:0;
            background:var(--gradient-primary);
            display:flex;align-items:center;justify-content:center;
            font-weight:700;font-size:1rem;color:#fff;
            border:2px solid ${isTop3 ? rankColor : 'rgba(123,30,43,.2)'};
          ">${u.name?.[0]?.toUpperCase() || '?'}</div>

          <!-- INFO -->
          <div style="flex:1;min-width:0">
            <div style="font-weight:700;font-size:.94rem;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
              ${u.name}
              ${isMe ? `<span style="font-size:.7rem;font-weight:700;background:var(--primary);color:#fff;padding:.15rem .5rem;border-radius:999px;margin-left:.4rem">You</span>` : ''}
            </div>
            <div style="font-size:.78rem;color:var(--text-muted);margin-top:.2rem">
              ${u.complaintsCount || 0} <%= __('reportsCountText') %> &nbsp;&middot;&nbsp; ${u.resolvedCount || 0} <%= __('resolvedCountText') %>
            </div>
          </div>

          <!-- POINTS -->
          <div style="text-align:right;flex-shrink:0">
            <div style="font-weight:700;font-size:1.2rem;color:${isTop3 ? rankColor : 'var(--primary-dark)'}">
              ${(u.points || 0).toLocaleString()}
            </div>
            <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted)"><%= __('ptsLabel') %></div>
          </div>
        </div>`;
            }).join('');
          } catch (e) {
            document.getElementById('list').innerHTML = `
      <div class="empty-state" style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:4rem 2rem">
        <div class="empty-title" data-i18n="failedToLoad"><%= __('failedToLoad') %></div>
      </div>`;
          }
        }

        loadLeaderboard();
      </script>
      </body>

      </html>