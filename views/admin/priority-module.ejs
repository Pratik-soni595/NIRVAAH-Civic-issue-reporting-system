<%- include('../partials/head') %>

<%- include('../partials/admin-navbar') %>

<div style="display:flex;min-height:100vh;padding-top:72px">
  <%- include('../partials/admin-sidebar', {navPage}) %>

  <div class="admin-main">
    <div class="page-header priority-page-header">
      <div>
        <h1>Priority Module</h1>
        <p class="text-muted">Vote-based workflow, deadline tracking, and escalation management.</p>
      </div>
      <div class="priority-header-actions">
        <button id="pm-escalate" class="priority-btn priority-btn-outline" type="button">Run Escalation</button>
      </div>
    </div>

    <div class="filter-bar priority-filter-bar">
      <div class="priority-filter-group">
        <label for="pm-priority">Priority</label>
        <select id="pm-priority" class="priority-select">
          <option value="">All Priority</option>
          <option value="high">High</option>
          <option value="medium">Medium</option>
          <option value="low">Low</option>
        </select>
      </div>

      <div class="priority-filter-group">
        <label for="pm-status">Status</label>
        <select id="pm-status" class="priority-select">
          <option value="">All Status</option>
          <option value="pending">Pending</option>
          <option value="approved">Approved</option>
          <option value="in_progress">In Progress</option>
          <option value="resolved">Resolved</option>
        </select>
      </div>

      <label class="priority-check">
        <input id="pm-overdue" type="checkbox">
        <span>Overdue only</span>
      </label>

      <button id="pm-filter" class="priority-btn priority-btn-primary" type="button">Apply Filters</button>
    </div>

    <div class="glass-card priority-table-shell">
      <div class="priority-table-meta">
        <div>
          <h3>Priority Queue</h3>
          <p id="pm-state-text" class="text-muted">Loading complaints...</p>
        </div>
      </div>

      <div class="priority-table-wrap">
        <table class="priority-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Category</th>
              <th>Location</th>
              <th>Votes</th>
              <th>Priority</th>
              <th>Deadline</th>
              <th>Countdown</th>
              <th>Status</th>
              <th>Level</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="pm-body">
            <tr>
              <td colspan="10" class="priority-state-cell text-muted">Loading complaints...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div id="pm-status-modal" class="pm-modal" aria-hidden="true">
  <div class="pm-modal-backdrop" data-close-modal></div>
  <div class="pm-modal-panel glass-card" role="dialog" aria-modal="true" aria-labelledby="pm-modal-title">
    <div class="pm-modal-header">
      <div>
        <h3 id="pm-modal-title">Update Status</h3>
        <p id="pm-modal-subtitle" class="text-muted">Select the next workflow step for this complaint.</p>
      </div>
      <button type="button" class="pm-modal-close" data-close-modal aria-label="Close">&times;</button>
    </div>

    <form id="statusForm" class="pm-modal-body">
      <div class="pm-modal-summary">
        <div>
          <span class="pm-summary-label">Complaint</span>
          <strong id="pm-modal-complaint">N/A</strong>
        </div>
        <div>
          <span class="pm-summary-label">Current Status</span>
          <strong id="pm-modal-current">N/A</strong>
        </div>
        <div>
          <span class="pm-summary-label">Level</span>
          <strong id="pm-modal-level">N/A</strong>
        </div>
      </div>

      <div class="priority-form-group">
        <label for="newStatus">New Status</label>
        <select id="newStatus" class="priority-select" required></select>
      </div>

      <div class="priority-form-group">
        <label for="statusNote">Note</label>
        <textarea id="statusNote" class="priority-textarea" rows="3" placeholder="Add an optional note for the workflow update"></textarea>
      </div>

      <div class="pm-modal-actions">
        <button type="button" class="priority-btn priority-btn-outline" data-close-modal>Cancel</button>
        <button type="submit" class="priority-btn priority-btn-primary">Update Status</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/scripts') %>
<script>
if (!window.NIRVAAH?.Auth.isLoggedIn() || !window.NIRVAAH.Auth.isAdmin()) {
  window.location.href = '/login';
}

const pmState = {
  items: [],
  currentComplaintId: null,
  currentComplaint: null,
  loading: false,
};

const statusLabels = {
  pending: 'Pending',
  approved: 'Approved',
  in_progress: 'In Progress',
  resolved: 'Resolved',
};

const priorityLabels = {
  high: 'High',
  medium: 'Medium',
  low: 'Low',
};

const transitionMap = {
  pending: ['approved'],
  approved: ['in_progress'],
  in_progress: ['resolved'],
  resolved: [],
};

function escapeHtml(value) {
  return String(value ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function formatDate(value) {
  if (!value) return 'N/A';
  const parsed = new Date(value);
  if (Number.isNaN(parsed.getTime())) return 'N/A';
  return parsed.toLocaleDateString();
}

function formatCountdown(countdown) {
  if (!countdown || typeof countdown.hoursLeft !== 'number') return 'N/A';
  if (countdown.isOverdue) return `Overdue by ${Math.abs(countdown.hoursLeft)}h`;
  return `${countdown.hoursLeft}h left`;
}

function getCountdownClass(countdown) {
  if (!countdown) return 'countdown-neutral';
  if (countdown.color === 'red') return 'countdown-red';
  if (countdown.color === 'yellow') return 'countdown-yellow';
  return 'countdown-green';
}

function getStatusBadgeClass(status) {
  return `status-badge status-badge-${String(status || '').toLowerCase()}`;
}

function getPriorityBadgeClass(priority) {
  return `priority-badge priority-badge-${String(priority || '').toLowerCase()}`;
}

function setStateText(message, isError = false) {
  const text = document.getElementById('pm-state-text');
  if (text) {
    text.textContent = message;
    text.classList.toggle('text-danger', isError);
  }
}

function setTableState(message, type = 'loading') {
  const tbody = document.getElementById('pm-body');
  if (!tbody) return;
  const className = type === 'error' ? 'priority-state-cell text-danger' : 'priority-state-cell text-muted';
  tbody.innerHTML = `<tr><td colspan="10" class="${className}">${escapeHtml(message)}</td></tr>`;
}

function statusOptions(currentStatus) {
  return transitionMap[currentStatus] || [];
}

function renderRows() {
  const tbody = document.getElementById('pm-body');
  if (!tbody) return;

  if (!pmState.items.length) {
    tbody.innerHTML = '<tr><td colspan="10" class="priority-state-cell text-muted">No complaints found for the selected filters.</td></tr>';
    setStateText('No complaints found for the selected filters.');
    return;
  }

  setStateText(`${pmState.items.length} complaint${pmState.items.length === 1 ? '' : 's'} loaded.`);

  tbody.innerHTML = pmState.items.map((item) => {
    const currentStatus = String(item.status || 'pending').toLowerCase();
    const options = statusOptions(currentStatus);
    const nextStatusLabel = options.map((status) => `<option value="${status}">${statusLabels[status] || status}</option>`).join('');
    const actionDisabled = options.length === 0;

    return `
      <tr>
        <td class="priority-title-cell">
          <a href="/admin/complaint?id=${item.complaintId}" target="_blank" rel="noreferrer">${escapeHtml(item.title || 'Untitled complaint')}</a>
        </td>
        <td>${escapeHtml((item.category || 'N/A').replace(/_/g, ' '))}</td>
        <td>${escapeHtml(item.location?.address || 'N/A')}</td>
        <td>${Number(item.votes || 0).toLocaleString()}</td>
        <td><span class="${getPriorityBadgeClass(item.priority)}">${escapeHtml(priorityLabels[currentPriorityKey(item.priority)] || item.priority || 'N/A')}</span></td>
        <td>${escapeHtml(formatDate(item.deadline))}</td>
        <td><span class="${getCountdownClass(item.countdown)}">${escapeHtml(formatCountdown(item.countdown))}</span></td>
        <td><span class="${getStatusBadgeClass(currentStatus)}">${escapeHtml(statusLabels[currentStatus] || currentStatus.replace(/_/g, ' '))}</span></td>
        <td>Level ${escapeHtml(item.level ?? 'N/A')}</td>
        <td>
          <div class="priority-action-group">
            <select id="pm-next-${item.complaintId}" class="priority-select priority-select-inline" ${actionDisabled ? 'disabled' : ''}>
              <option value="">${actionDisabled ? 'No further transition' : 'Select next step'}</option>
              ${nextStatusLabel}
            </select>
            <button type="button" class="priority-btn priority-btn-outline priority-btn-sm" onclick="openStatusModal('${item.complaintId}')" ${actionDisabled ? 'disabled' : ''}>Update</button>
          </div>
        </td>
      </tr>
    `;
  }).join('');
}

function currentPriorityKey(priority) {
  const value = String(priority || '').toLowerCase();
  return ['high', 'medium', 'low'].includes(value) ? value : 'low';
}

function openStatusModal(complaintId) {
  const complaint = pmState.items.find((item) => String(item.complaintId) === String(complaintId));
  if (!complaint) {
    showToast('Error', 'Complaint not found.', 'error');
    return;
  }

  const currentStatus = String(complaint.status || 'pending').toLowerCase();
  const nextSelect = document.getElementById(`pm-next-${complaintId}`);
  const nextStatus = nextSelect?.value || statusOptions(currentStatus)[0] || '';
  const modal = document.getElementById('pm-status-modal');
  const newStatus = document.getElementById('newStatus');

  pmState.currentComplaintId = complaintId;
  pmState.currentComplaint = complaint;

  document.getElementById('pm-modal-title').textContent = 'Update Status';
  document.getElementById('pm-modal-subtitle').textContent = 'Select the next workflow step for this complaint.';
  document.getElementById('pm-modal-complaint').textContent = complaint.title || 'Untitled complaint';
  document.getElementById('pm-modal-current').textContent = statusLabels[currentStatus] || currentStatus;
  document.getElementById('pm-modal-level').textContent = `Level ${complaint.level ?? 'N/A'}`;
  document.getElementById('statusNote').value = '';

  newStatus.innerHTML = statusOptions(currentStatus).map((status) => `<option value="${status}">${statusLabels[status] || status}</option>`).join('');
  if (nextStatus) newStatus.value = nextStatus;

  modal.classList.add('is-open');
  modal.setAttribute('aria-hidden', 'false');
}

function closeModal() {
  const modal = document.getElementById('pm-status-modal');
  modal.classList.remove('is-open');
  modal.setAttribute('aria-hidden', 'true');
  pmState.currentComplaintId = null;
  pmState.currentComplaint = null;
}

async function loadComplaints(options = {}) {
  const { silent = false } = options;
  const priority = document.getElementById('pm-priority').value;
  const status = document.getElementById('pm-status').value;
  const overdue = document.getElementById('pm-overdue').checked;

  const filters = {};
  if (priority) filters.priority = priority;
  if (status) filters.status = status;
  if (overdue) filters.overdue = true;

  if (!silent) {
    pmState.loading = true;
    setTableState('Loading complaints...');
    setStateText('Loading complaints...');
  }

  try {
    const response = await window.NIRVAAH.AdminPriority.getDashboard(filters);
    pmState.items = Array.isArray(response?.complaints) ? response.complaints : [];
    renderRows();
  } catch (error) {
    console.error('Error loading priority dashboard:', error);
    pmState.items = [];
    setStateText(error.message || 'Failed to load complaints.', true);
    setTableState(error.message || 'Failed to load complaints.', 'error');
    showToast('Error', error.message || 'Failed to load complaints.', 'error');
  } finally {
    pmState.loading = false;
  }
}

async function updateStage(complaintId) {
  const next = document.getElementById(`pm-next-${complaintId}`)?.value;
  if (!next) {
    showToast('Error', 'Please select a next status.', 'error');
    return;
  }

  try {
    const note = document.getElementById('statusNote').value.trim() || 'Updated from priority module';
    await window.NIRVAAH.AdminPriority.updateStatus(complaintId, next, note);
    showToast('Updated', 'Workflow status updated successfully.', 'success');
    closeModal();
    await loadComplaints({ silent: true });
  } catch (error) {
    console.error('Error updating complaint status:', error);
    showToast('Error', error.message || 'Status update failed.', 'error');
  }
}

async function runEscalationJob() {
  const button = document.getElementById('pm-escalate');
  const originalText = button.textContent;
  button.disabled = true;
  button.textContent = 'Running...';

  try {
    const response = await window.NIRVAAH.AdminPriority.runEscalation();
    const count = response?.escalatedCount ?? 0;
    showToast('Escalation complete', `${count} complaint${count === 1 ? '' : 's'} escalated.`, 'success');
    await loadComplaints({ silent: true });
  } catch (error) {
    console.error('Error running escalation:', error);
    showToast('Error', error.message || 'Escalation failed.', 'error');
  } finally {
    button.disabled = false;
    button.textContent = originalText;
  }
}

function bindEvents() {
  document.getElementById('pm-filter').addEventListener('click', () => loadComplaints());
  document.getElementById('pm-escalate').addEventListener('click', runEscalationJob);
  document.getElementById('statusForm').addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!pmState.currentComplaintId) return;
    const nextStatus = document.getElementById('newStatus').value;
    const currentSelect = document.getElementById(`pm-next-${pmState.currentComplaintId}`);
    if (currentSelect) currentSelect.value = nextStatus;
    await updateStage(pmState.currentComplaintId);
  });

  document.querySelectorAll('[data-close-modal]').forEach((element) => {
    element.addEventListener('click', closeModal);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeModal();
  });
}

bindEvents();
setInterval(() => loadComplaints({ silent: true }), 30000);
loadComplaints();
</script>

<style>
  .priority-page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .priority-header-actions {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .priority-filter-bar {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: end;
    padding: 1rem 1.1rem;
    margin-bottom: 1.5rem;
  }

  .priority-filter-group {
    display: flex;
    flex-direction: column;
    gap: .35rem;
    min-width: 180px;
  }

  .priority-filter-group label,
  .priority-form-group label {
    font-size: .8rem;
    font-weight: 700;
    letter-spacing: .02em;
    color: var(--text-muted, #6b7280);
  }

  .priority-check {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    min-height: 42px;
    padding-bottom: .15rem;
    font-size: .9rem;
    color: var(--text, #334155);
    user-select: none;
  }

  .priority-select,
  .priority-textarea {
    width: 100%;
    border: 1px solid var(--border, rgba(148, 163, 184, .35));
    border-radius: 12px;
    padding: .72rem .9rem;
    background: var(--bg, #fff);
    color: var(--text, #0f172a);
    outline: none;
    transition: border-color .15s ease, box-shadow .15s ease, transform .15s ease;
  }

  .priority-select:focus,
  .priority-textarea:focus {
    border-color: rgba(37, 99, 235, .55);
    box-shadow: 0 0 0 4px rgba(37, 99, 235, .08);
  }

  .priority-select-inline {
    min-width: 150px;
    max-width: 190px;
  }

  .priority-btn {
    border: 1px solid transparent;
    border-radius: 12px;
    padding: .72rem 1rem;
    font-weight: 700;
    letter-spacing: .01em;
    cursor: pointer;
    transition: transform .15s ease, box-shadow .15s ease, background .15s ease, border-color .15s ease;
  }

  .priority-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 22px rgba(15, 23, 42, .08);
  }

  .priority-btn:disabled {
    opacity: .6;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .priority-btn-primary {
    background: linear-gradient(135deg, #7a1c1c, #9c2626);
    color: #fff;
  }

  .priority-btn-outline {
    background: rgba(255, 255, 255, .75);
    border-color: var(--border, rgba(148, 163, 184, .35));
    color: var(--text, #334155);
  }

  .priority-btn-sm {
    padding: .55rem .8rem;
    border-radius: 10px;
    font-size: .85rem;
  }

  .priority-table-shell {
    padding: 0;
    overflow: hidden;
  }

  .priority-table-meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.25rem 0;
  }

  .priority-table-meta h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
  }

  .priority-table-meta p {
    margin: .25rem 0 0;
  }

  .priority-table-wrap {
    overflow: auto;
  }

  .priority-table {
    width: 100%;
    min-width: 1080px;
    border-collapse: separate;
    border-spacing: 0;
  }

  .priority-table thead th {
    position: sticky;
    top: 0;
    z-index: 1;
    background: rgba(248, 250, 252, .96);
    backdrop-filter: blur(12px);
    text-align: left;
    padding: 1rem .95rem;
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--text-muted, #64748b);
    border-bottom: 1px solid var(--border, rgba(148, 163, 184, .25));
  }

  .priority-table tbody td {
    padding: .95rem .95rem;
    border-bottom: 1px solid rgba(148, 163, 184, .12);
    vertical-align: middle;
    color: var(--text, #0f172a);
    font-size: .92rem;
  }

  .priority-table tbody tr:hover {
    background: rgba(248, 250, 252, .72);
  }

  .priority-title-cell a {
    color: var(--text, #0f172a);
    font-weight: 700;
    text-decoration: none;
  }

  .priority-title-cell a:hover {
    text-decoration: underline;
  }

  .priority-action-group {
    display: flex;
    gap: .6rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .priority-badge,
  .status-badge,
  .countdown-red,
  .countdown-yellow,
  .countdown-green,
  .countdown-neutral {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: .34rem .7rem;
    border-radius: 999px;
    font-size: .74rem;
    font-weight: 800;
    letter-spacing: .03em;
    text-transform: uppercase;
    border: 1px solid transparent;
    white-space: nowrap;
  }

  .priority-badge-high {
    background: rgba(220, 38, 38, .08);
    color: #dc2626;
    border-color: rgba(220, 38, 38, .16);
  }

  .status-badge-approved {
    background: rgba(59, 130, 246, .1);
    color: #2563eb;
    border-color: rgba(59, 130, 246, .18);
  }

  .priority-badge-medium,
  .status-badge-pending,
  .status-badge-in_progress {
    background: rgba(245, 158, 11, .1);
    color: #d97706;
    border-color: rgba(245, 158, 11, .18);
  }

  .priority-badge-low,
  .status-badge-resolved {
    background: rgba(16, 185, 129, .1);
    color: #059669;
    border-color: rgba(16, 185, 129, .18);
  }

  .countdown-red {
    background: rgba(220, 38, 38, .08);
    color: #dc2626;
    border-color: rgba(220, 38, 38, .16);
  }

  .countdown-yellow {
    background: rgba(245, 158, 11, .1);
    color: #d97706;
    border-color: rgba(245, 158, 11, .18);
  }

  .countdown-green {
    background: rgba(16, 185, 129, .1);
    color: #059669;
    border-color: rgba(16, 185, 129, .18);
  }

  .countdown-neutral {
    background: rgba(148, 163, 184, .12);
    color: #475569;
    border-color: rgba(148, 163, 184, .2);
  }

  .priority-state-cell {
    text-align: center;
    padding: 3rem 1rem !important;
    font-weight: 600;
  }

  .pm-modal {
    position: fixed;
    inset: 0;
    z-index: 1100;
    display: none;
  }

  .pm-modal.is-open {
    display: block;
  }

  .pm-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, .52);
    backdrop-filter: blur(4px);
  }

  .pm-modal-panel {
    position: relative;
    width: min(560px, calc(100vw - 2rem));
    margin: 8vh auto 0;
    padding: 1.25rem;
    border-radius: 20px;
    box-shadow: 0 24px 60px rgba(15, 23, 42, .22);
  }

  .pm-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .pm-modal-header h3 {
    margin: 0;
    font-size: 1.15rem;
  }

  .pm-modal-header p {
    margin: .3rem 0 0;
  }

  .pm-modal-close {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid var(--border, rgba(148, 163, 184, .3));
    background: rgba(255, 255, 255, .9);
    color: var(--text, #0f172a);
    font-size: 1.3rem;
    line-height: 1;
    cursor: pointer;
  }

  .pm-modal-body {
    display: grid;
    gap: 1rem;
  }

  .pm-modal-summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: .75rem;
  }

  .pm-modal-summary > div {
    padding: .9rem;
    border-radius: 14px;
    background: rgba(248, 250, 252, .82);
    border: 1px solid rgba(148, 163, 184, .18);
  }

  .pm-summary-label {
    display: block;
    margin-bottom: .35rem;
    font-size: .72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--text-muted, #64748b);
  }

  .priority-form-group {
    display: grid;
    gap: .4rem;
  }

  .pm-modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: .75rem;
    flex-wrap: wrap;
  }

  @media (max-width: 960px) {
    .priority-page-header,
    .priority-filter-bar {
      flex-direction: column;
      align-items: stretch;
    }

    .priority-filter-group,
    .priority-check {
      min-width: 100%;
    }

    .pm-modal-summary {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .priority-table-meta,
    .priority-table-shell {
      padding-inline: 0;
    }

    .priority-table-meta {
      padding: 1rem 1rem 0;
    }

    .priority-btn,
    .priority-select,
    .priority-textarea {
      width: 100%;
    }

    .priority-action-group {
      flex-direction: column;
      align-items: stretch;
    }

    .priority-btn-sm,
    .priority-select-inline {
      max-width: none;
      min-width: 100%;
    }

    .pm-modal-panel {
      margin-top: 4vh;
