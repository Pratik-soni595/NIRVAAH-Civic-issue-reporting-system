<%- include('../partials/head') %>

<%- include('../partials/admin-navbar') %>

<div style="display:flex;min-height:100vh;padding-top:72px">
  <%- include('../partials/admin-sidebar', {navPage}) %>

  <div class="admin-main">
    <div class="page-header text-center">
      <h1 data-i18n="communityLeaderboard" style="font-weight:700; color:var(--text-main, #333); margin-bottom:0.5rem;"><%- __('communityLeaderboard') %></h1>
      <p class="text-muted mt-1" data-i18n="lbSubtitle" style="font-size:1.1rem;"><%= __('lbSubtitle') %></p>
    </div>

    <!-- Points Legend -->
    <div style="display:flex;gap:1.5rem;flex-wrap:wrap;justify-content:center;margin-bottom:3rem">
      <div class="glass-card" style="padding:1.5rem 2rem;text-align:center; min-width:180px; border:1px solid var(--border,#e5e7eb); border-radius:8px;">
        <strong style="font-size:1.25rem;color:var(--text-main,#333);">+10 Points</strong><br>
        <span class="text-muted text-sm mt-2" style="display:block;" data-i18n="perReport"><%= __('perReport') %></span>
      </div>
      <div class="glass-card" style="padding:1.5rem 2rem;text-align:center; min-width:180px; border:1px solid var(--border,#e5e7eb); border-radius:8px;">
        <strong style="font-size:1.25rem;color:var(--text-main,#333);">+2 Points</strong><br>
        <span class="text-muted text-sm mt-2" style="display:block;" data-i18n="perUpvote"><%= __('perUpvote') %></span>
      </div>
      <div class="glass-card" style="padding:1.5rem 2rem;text-align:center; min-width:180px; border:1px solid rgba(16,185,129,.4); border-radius:8px; background:rgba(16,185,129,.05);">
        <strong style="color:var(--resolved, #10b981);font-size:1.25rem;">+25 Points</strong><br>
        <span class="text-muted text-sm mt-2" style="display:block;" data-i18n="onResolved"><%= __('onResolved') %></span>
      </div>
    </div>

    <div style="max-width:800px;margin:0 auto">
      <div id="list"><div class="loading-center"><div class="spinner"></div></div></div>
    </div>
  </div>
</div>

<%- include('../partials/scripts') %>
<script>
if (!window.NIRVAAH?.Auth.isLoggedIn() || !window.NIRVAAH.Auth.isAdmin()) {
  window.location.href = '/login';
}

const colors = ['#d4af37', '#71717a', '#b08d57']; // Gold, Silver, Bronze style
async function loadLeaderboard() {
  try {
    const data = await window.NIRVAAH.Users.getLeaderboard();
    const leaders = data.leaderboard || [];
    if (!leaders.length) { 
        document.getElementById('list').innerHTML = `<div class="glass-card" style="padding:4rem;text-align:center;border:1px solid var(--border,#e5e7eb); border-radius:8px;"><h3 class="text-muted" data-i18n="noDataYet" style="font-weight:500;"><%= __('noDataYet') %></h3></div>`; 
        return; 
    }
    
    document.getElementById('list').innerHTML = leaders.map((u, i) => {
      const rankColor = i < 3 ? colors[i] : 'var(--text-muted, #9ca3af)';
      let rankText = i + 1;
      if (i === 0) rankText = '1st';
      else if (i === 1) rankText = '2nd';
      else if (i === 2) rankText = '3rd';
      else rankText = (i + 1) + 'th';

      return `
      <div class="glass-card" style="display:flex;align-items:center;padding:1.25rem 1.75rem;margin-bottom:1rem;gap:1.5rem;transition:transform 0.2s ease, box-shadow 0.2s ease; border:1px solid var(--border,#e5e7eb); border-left: 4px solid ${i<3 ? rankColor : 'transparent'}; border-radius:8px;">
        <div style="font-size:1.15rem;font-weight:700;width:48px;text-align:center;color:${rankColor}">${rankText}</div>
        <div class="nav-avatar" style="width:48px;height:48px;font-size:1.25rem;background:#f3f4f6;color:#555;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:600;border:1px solid #e5e7eb;">${u.name?.[0]?.toUpperCase()||'?'}</div>
        <div style="flex:1">
            <div style="font-weight:600;font-size:1.15rem;margin-bottom:.25rem;color:var(--text-main,#1f2937);">${u.name}</div>
            <div style="font-size:.85rem;color:var(--text-muted, #6b7280)">${u.complaintsCount||0} <%= __("reportsCountText") %> &nbsp;·&nbsp; <span style="color:var(--resolved, #10b981);font-weight:500;">${u.resolvedCount||0} <%= __("resolvedCountText") %></span></div>
        </div>
        <div style="text-align:right">
            <div style="font-size:1.5rem;font-weight:700;color:var(--text-main,#1f2937);line-height:1">${(u.points||0).toLocaleString()}</div>
            <div style="font-size:.7rem;color:var(--text-muted, #6b7280);text-transform:uppercase;letter-spacing:1px;margin-top:.35rem;font-weight:600;"><%= __("points") %></div>
        </div>
      </div>`;
    }).join('');
  } catch(e) { 
      document.getElementById('list').innerHTML = `<div class="glass-card" style="padding:4rem;text-align:center;border:1px solid var(--warning, #f59e0b); border-radius:8px;"><h3 class="text-danger" data-i18n="failedToLoadLb" style="color:#ef4444;font-weight:500;"><%= __('failedToLoadLb') %></h3></div>`; 
      console.error(e);
  }
}
loadLeaderboard();
</script>
</body></html>
