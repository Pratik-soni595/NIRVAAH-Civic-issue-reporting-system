<%- include('../partials/head') %>

<%- include('../partials/admin-navbar') %>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<div style="display:flex;min-height:100vh;padding-top:72px">
  <%- include('../partials/admin-sidebar', {navPage}) %>

  <div class="admin-main">
    <div class="page-header">
      <h1 data-i18n="adminDashboardTitle"><%= __('adminDashboardTitle') %></h1>
      <p class="text-muted" data-i18n="systemOverview"><%= __('systemOverview') %></p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem">
      <div class="glass-card" style="padding:1.5rem"><h3 style="margin-bottom:1rem;font-size:1rem" data-i18n="issuesByCat"><%= __('issuesByCat') %></h3><canvas id="catChart" height="220"></canvas></div>
      <div class="glass-card" style="padding:1.5rem"><h3 style="margin-bottom:1rem;font-size:1rem" data-i18n="statusDist"><%= __('statusDist') %></h3><canvas id="statChart" height="220"></canvas></div>
    </div>
    <div class="glass-card" style="padding:1.5rem;margin-bottom:2rem"><h3 style="margin-bottom:1rem;font-size:1rem" data-i18n="reportsTrend"><%= __('reportsTrend') %></h3><canvas id="trendChart" height="100"></canvas></div>


  </div>
</div>

<%- include('../partials/scripts') %>
<script>
if (!window.NIRVAAH?.Auth.isLoggedIn() || !window.NIRVAAH.Auth.isAdmin()) window.location.href = '/login';
const sLabel = {pending:'Pending',in_progress:'In Progress',resolved:'Resolved'};
const cIcons = {pothole:'',garbage:'',water_leakage:'',electricity:'',road_damage:'',street_light:'',sewage:'',tree_hazard:'',graffiti:'',other:''};

async function load() {
  try {
    const [analytics, recent] = await Promise.all([
      window.NIRVAAH.Admin.getAnalytics(),
      window.NIRVAAH.Admin.getComplaints({ limit:8, sortBy:'createdAt', sortOrder:'desc' })
    ]);
    renderCharts(analytics.analytics);
    renderTable(recent.complaints||[]);
  } catch(e) { showToast('Error','<%= __("failedToLoadAnalytics") %>'+e.message,'error'); }
}

function renderCharts(a) {
  const catData = (a.byCategory||[]).slice(0,8);
  new Chart(document.getElementById('catChart'),{ type:'bar', data:{labels:catData.map(d=>(cIcons[d._id]||'📍')+' '+d._id.replace('_',' ')),datasets:[{data:catData.map(d=>d.count),backgroundColor:'#6366f1aa',borderColor:'#6366f1',borderWidth:1,borderRadius:6}]}, options:{plugins:{legend:{display:false}},scales:{x:{ticks:{color:'#94a3b8'},grid:{color:'rgba(255,255,255,.04)'}},y:{ticks:{color:'#94a3b8'},grid:{color:'rgba(255,255,255,.04)'}}}} });
  new Chart(document.getElementById('statChart'),{ type:'doughnut', data:{labels:['Pending','In Progress','Resolved'],datasets:[{data:[a.overview.pending,a.overview.inProgress,a.overview.resolved],backgroundColor:['#ef444466','#f59e0b66','#10b98166'],borderColor:['#ef4444','#f59e0b','#10b981'],borderWidth:2}]}, options:{plugins:{legend:{labels:{color:'#94a3b8'}}},cutout:'65%'} });
  const t=a.dailyTrend||[];
  new Chart(document.getElementById('trendChart'),{ type:'line', data:{labels:t.map(d=>d._id),datasets:[{label:'Reports',data:t.map(d=>d.count),borderColor:'#6366f1',backgroundColor:'rgba(99,102,241,.08)',fill:true,tension:.4,pointBackgroundColor:'#6366f1'}]}, options:{plugins:{legend:{labels:{color:'#94a3b8'}}},scales:{x:{ticks:{color:'#94a3b8'},grid:{color:'rgba(255,255,255,.04)'}},y:{ticks:{color:'#94a3b8'},grid:{color:'rgba(255,255,255,.04)'}}}} });
}

function renderTable(list) {
  // Removed Recent Reports Table
}


async function updateStatus(id, status, el) {
  try { await window.NIRVAAH.Admin.updateStatus(id, status); showToast('Updated ✅','Status updated.','success'); el.value=''; load(); }
  catch(e) { showToast('Error',e.message,'error'); }
}

load();
</script>
</body></html>
