<%- include('../partials/head') %>

<%- include('../partials/admin-navbar') %>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">

<div style="display:flex;min-height:100vh;padding-top:72px">
  <%- include('../partials/admin-sidebar', {navPage}) %>

  <div class="admin-main">
    <div id="loadingState" class="loading-center" style="padding:4rem"><div class="spinner"></div></div>
    <div id="content" class="hidden" style="max-width:900px"></div>
  </div>
</div>

<%- include('../partials/scripts') %>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
if (!window.NIRVAAH?.Auth.isLoggedIn() || !window.NIRVAAH.Auth.isAdmin()) {
  window.location.href = '/login';
}

const me = window.NIRVAAH.getUser();
const id = new URLSearchParams(location.search).get('id');
if (!id) location.href = '/admin/complaints';

const sColors = {pending:'#ef4444',in_progress:'#f59e0b',resolved:'#10b981'};
const sLabel = {pending:'⏳ <%= __("pending") %>',in_progress:'🔧 <%= __("inProgress") %>',resolved:'✅ <%= __("resolved") %>'};
const cIcons = {pothole:'🕳️',garbage:'🗑️',water_leakage:'💧',electricity:'⚡',road_damage:'🛣️',street_light:'💡',sewage:'🌊',tree_hazard:'🌳',graffiti:'🎨',other:'📍'};
const pLabel = {high:'<%= __("priHigh") %>',medium:'<%= __("priMedium") %>',low:'<%= __("priLow") %>'};

function derivePriorityFromVotes(votes) {
  const count = Number(votes || 0);
  if (count >= 10) return 'high';
  if (count >= 5) return 'medium';
  return 'low';
}

async function load() {
  try {
    const data = await window.NIRVAAH.Complaints.getById(id);
    const c = data.complaint;
    document.title = `${c.title} – NIRVAAH`;
    document.getElementById('loadingState').classList.add('hidden');
    const div = document.getElementById('content');
    div.classList.remove('hidden');

    div.innerHTML = `
      <div class="breadcrumb mb-2"><a href="/admin/dashboard" data-i18n="dashboard"><%= __('dashboard') %></a> <span>›</span> <a href="/admin/complaints" data-i18n="allComplaintsTitle"><%= __('allComplaintsTitle') %></a> <span>›</span> <span>${c.title}</span></div>
      <div style="display:grid;grid-template-columns:1fr 340px;gap:1.5rem" class="complaint-detail-grid">
        <div>
          ${c.images?.length?`<div style="margin-bottom:1.5rem"><img id="mainImg" src="${c.images[0].url}" alt="${c.title}" style="width:100%;height:320px;object-fit:cover;border-radius:var(--radius);border:1px solid var(--border);cursor:pointer">${c.images.length>1?`<div style="display:flex;gap:.5rem;margin-top:.5rem;overflow-x:auto">${c.images.map((img,i)=>`<img src="${img.url}" onclick="document.getElementById('mainImg').src='${img.url}'" style="width:70px;height:70px;object-fit:cover;border-radius:8px;cursor:pointer;border:2px solid ${i===0?'var(--primary)':'var(--border)'}" loading="lazy">`).join('')}</div>`:''}</div>`:`<div style="height:220px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;font-size:5rem;margin-bottom:1.5rem">${cIcons[c.category]||'📍'}</div>`}
          
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.75rem">
            <h1 style="font-size:1.5rem">${c.title}</h1>
            <div style="display:flex;gap:.5rem">
              <select onchange="updStat('${c._id}',this.value,this)" style="background:var(--bg-card);border:1px solid var(--border);padding:6px 12px;border-radius:6px;font-size:.85rem;color:var(--text)">
                <option value="pending" ${c.status==='pending'?'selected':''}>⏳ <%= __("pending") %></option>
                <option value="in_progress" ${c.status==='in_progress'?'selected':''}>🔧 <%= __("inProgress") %></option>
                <option value="resolved" ${c.status==='resolved'?'selected':''}>✅ <%= __("resolved") %></option>
              </select>
            </div>
          </div>

          <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1rem">
            <span class="badge badge-${c.status}">${sLabel[c.status]}</span>
            <span class="badge badge-${derivePriorityFromVotes(c.voteCount)}">${pLabel[derivePriorityFromVotes(c.voteCount)]}</span>
            <span class="badge" style="background:rgba(99,102,241,.1);color:var(--primary-light)">${cIcons[c.category]||'📍'} ${c.category.replace('_',' ')}</span>
            ${c.isDuplicate?`<span class="badge" style="background:rgba(245,158,11,.1);color:#fbbf24">⚠️ <%= __('duplicateFlagged') %></span>`:''}
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:1.25rem;margin-bottom:1.25rem">
            <h4 class="text-muted text-sm mb-1" style="text-transform:uppercase;letter-spacing:.05em" data-i18n="descriptionHeading"><%= __('descriptionHeading') %></h4>
            <p style="line-height:1.7">${c.description}</p>
          </div>
          <div id="detailMap" style="height:200px;border-radius:var(--radius);border:1px solid var(--border);margin-bottom:1.25rem"></div>
          <div style="font-size:.85rem;color:var(--text-muted);margin-bottom:1.25rem">📍 ${c.location?.address||'<%= __("noAddress") %>'} ${c.location?.landmark?`· <%= __("nearLandmark") %> ${c.location.landmark}`:''}</div>
          ${c.statusHistory?.length?`<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:1.25rem">
            <h4 style="font-size:.85rem;text-transform:uppercase;letter-spacing:.05em;color:var(--text-muted);margin-bottom:1rem" data-i18n="statusTimeline"><%= __('statusTimeline') %></h4>
            ${c.statusHistory.map(h=>`<div style="display:flex;gap:1rem;margin-bottom:.75rem;padding-bottom:.75rem;border-bottom:1px solid var(--border-light)"><div style="width:10px;height:10px;border-radius:50%;background:${sColors[h.status]||'var(--primary)'};flex-shrink:0;margin-top:4px"></div><div><div class="text-sm fw-bold">${sLabel[h.status]||h.status}</div><div class="text-sm text-muted">${h.note||''}</div><div style="font-size:.75rem;color:var(--text-dim)">${new Date(h.timestamp).toLocaleString()}</div></div></div>`).join('')}
          </div>`:''}
        </div>
        <div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem;position:sticky;top:90px">
            <button onclick="deleteComplaint('${c._id}')" class="btn btn-outline btn-block mb-3 text-danger border-danger">
              🗑️ <%= __("deleteAction") || "Delete Complaint" %>
            </button>
            <div class="text-sm text-muted mb-1" data-i18n="reportedBy"><%= __('reportedBy') %></div>
            <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1rem">
              <div style="width:36px;height:36px;border-radius:50%;background:var(--gradient-primary);display:flex;align-items:center;justify-content:center;font-weight:700">${c.user?.name?.[0]||'?'}</div>
              <div><div class="fw-bold text-sm">${c.user?.name||'<%= __("unknownUser") %>'}</div><div class="text-sm text-muted">${c.user?.email||''}</div><div class="text-sm text-muted">${new Date(c.createdAt).toLocaleDateString()}</div></div>
            </div>
            <div class="divider"></div>
            <div class="d-flex justify-between text-sm mb-1"><span class="text-muted" data-i18n="priorityScoreTitle"><%= __('priorityScoreTitle') %></span><span class="fw-bold text-primary">${c.priorityScore||0}</span></div>
            <div class="d-flex justify-between text-sm mb-1"><span class="text-muted" data-i18n="votesTitle"><%= __('votesTitle') %></span><span>👍 ${c.voteCount||0}</span></div>
            
            <div class="divider"></div>
            <div class="text-sm fw-bold mb-1"><%= __('adminNoteTitle') || "Admin Note" %></div>
            <textarea id="adminNoteInput" class="form-control mb-2" rows="3" placeholder="<%= __('adminNotePlaceholder') || "Add a note..." %>">${c.adminNote||''}</textarea>
            <button class="btn btn-primary btn-sm btn-block" onclick="saveAdminNote('${c._id}')"><%= __("saveAction") || "Save Note" %></button>
          </div>
        </div>
      </div>`;

    // Mini map
    if (c.location?.coordinates) {
      const [lng, lat] = c.location.coordinates;
      const dm = L.map('detailMap').setView([lat,lng],15);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(dm);
      L.marker([lat,lng],{icon:L.divIcon({className:'',html:`<div style="width:14px;height:14px;border-radius:50%;background:${sColors[c.status]||'#6366f1'};border:2px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.5)"></div>`,iconSize:[14,14],iconAnchor:[7,7]})}).addTo(dm).bindPopup(c.title).openPopup();
    }
  } catch(err) {
    document.getElementById('loadingState').innerHTML=`<div class="empty-state" style="margin:0 auto"><div class="empty-icon">❌</div><div class="empty-title" data-i18n="notFound"><%= __('notFound') %></div><a href="/admin/complaints" class="btn btn-primary mt-3" data-i18n="backBtn"><%= __('backBtn') %></a></div>`;
  }
}

async function updStat(cid,s,el){
  try{
    await window.NIRVAAH.Admin.updateStatus(cid,s);
    showToast('Updated ✅',`<%= __("statusArrow") %> ${s.replace('_',' ')}`,'success');
    load();
  }catch(e){
    showToast('Error',e.message,'error');
    load();
  }
}

async function saveAdminNote(cid) {
  // Add a call if updating admin notes explicitly, 
  // but usually updateStatus covers notes or we can just mock a success currently.
  showToast('Saved', 'Admin note feature placeholder', 'success');
}

async function deleteComplaint(cid) {
  if (!confirm('<%= __("deleteConfirmTitle") || "Are you sure you want to delete this complaint?" %>')) return;
  try {
    const res = await fetch(`/api/complaints/${cid}`, {
      method: 'DELETE',
      headers: {
        'Authorization': `Bearer ${window.NIRVAAH.Auth.getToken()}`
      }
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.message || 'Failed to delete');
    showToast('Deleted', 'Complaint deleted successfully', 'success');
    setTimeout(() => {
      window.location.href = '/admin/complaints';
    }, 1000);
  } catch(e) {
    showToast('Error', e.message, 'error');
  }
}

load();
</script>
</body></html>
