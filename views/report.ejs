<%- include('partials/head') %>
<link rel="stylesheet" href="/css/report-govt.css">
<%- include('partials/navbar', {navPage}) %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">

<div class="page-wrapper report-page">
  <div class="container report-container">
    <div class="page-header stagger-1">
      <div class="breadcrumb">
        <a href="/dashboard" data-i18n="dashboard"><%= __('dashboard') %></a> 
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span data-i18n="reportTitle"><%= __('reportTitle') %></span>
      </div>
      <h1 data-i18n="reportTitle"><%= __('reportTitle') %></h1>
      <p class="text-muted" data-i18n="reportSubtitle"><%= __('reportSubtitle') %></p>
    </div>

    <!-- Modern Stepper -->
    <div class="stepper-container stagger-1">
      <div class="stepper-line"></div>
      <div class="stepper-line" style="background:transparent;z-index:1;overflow:hidden">
        <div id="stepProgressFill" class="stepper-progress-fill" style="width:0%"></div>
      </div>
      
      <div id="ind1" class="stepper-step active">
        <div class="stepper-circle">1</div>
        <div class="stepper-label" data-i18n="step1Title"><%= __('step1Title') %></div>
      </div>
      <div id="ind2" class="stepper-step">
        <div class="stepper-circle">2</div>
        <div class="stepper-label" data-i18n="step2Title"><%= __('step2Title') %></div>
      </div>
      <div id="ind3" class="stepper-step">
        <div class="stepper-circle">3</div>
        <div class="stepper-label" data-i18n="step3Title"><%= __('step3Title') %></div>
      </div>
    </div>

    <form id="reportForm" novalidate>
      <!-- STEP 1: Photos & Category -->
      <div id="step1" class="report-card stagger-2">
        <div class="report-card-title">
          <svg style="width:24px;height:24px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <span data-i18n="uploadPhotos"><%= __('uploadPhotos') %></span>
        </div>
        
        <div class="premium-dropzone" id="dropzone" onclick="document.getElementById('imageInput').click()">
          <svg class="dropzone-icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
          <div>
            <div class="dropzone-title"><strong data-i18n="clickToUpload"><%= __('clickToUpload') %></strong> <%= __('orDragDrop') %></div>
            <div class="dropzone-hint" data-i18n="uploadHint"><%= __('uploadHint') %></div>
          </div>
        </div>
        <input type="file" id="imageInput" multiple accept="image/*" class="hidden" onchange="handleImages(this.files)">
        <div class="preview-grid" id="previewGrid"></div>
        <div class="text-danger text-sm mt-1 hidden" id="imgErr" data-i18n="errImageRequired">At least one image is required.</div>

        <div id="aiBox" class="info-card hidden mt-2" style="padding:1rem">
          <strong data-i18n="aiSuggests"><%= __('aiSuggests') %></strong> <span id="aiCat" style="color:var(--report-maroon);font-weight:600"></span>
          <button type="button" onclick="acceptAI()" class="report-btn report-btn-primary report-btn-sm" style="margin-left:1rem" data-i18n="useIt"><%= __('useIt') %></button>
        </div>

        <div class="form-group mt-3">
          <label class="form-label" data-i18n="issueCategory"><%= __('issueCategory') %></label>
          <div class="category-chips" id="chips">
            <% const cats = [['pothole',__('catPothole')],['garbage',__('catGarbage')],['water_leakage',__('catWaterLeak')],['electricity',__('catElectricity')],['road_damage',__('catRoadDamage')],['street_light',__('catStreetLight')],['sewage',__('catSewage')],['tree_hazard',__('catTreeHazard')],['graffiti',__('catGraffiti')],['other',__('catOther')]]; %>
            <% cats.forEach(([val, label]) => { %>
              <span class="category-chip" data-cat="<%= val %>" onclick="selectCat('<%= val %>')"><%= label %></span>
            <% }) %>
          </div>
          <input type="hidden" id="category" required>
          <div class="text-danger text-sm mt-1 hidden" id="catErr" data-i18n="errCategory"><%= __('errCategory') %></div>
        </div>
        
        <div class="report-actions right">
          <button type="button" onclick="goStep(2)" class="report-btn report-btn-primary">
            <%= __('nextAddDetails') %>
            <svg style="width:20px;height:20px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>

      <!-- STEP 2: Details -->
      <div id="step2" class="report-card hidden stagger-2">
        <div class="report-card-title">
          <svg style="width:24px;height:24px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          <span data-i18n="issueDetails"><%= __('issueDetails') %></span>
        </div>
        
        <div class="form-group">
          <label class="form-label" data-i18n="titleLabel"><%= __('titleLabel') %></label>
          <input type="text" class="report-input" id="title" data-i18n-placeholder="titlePlaceholder" placeholder="<%= __('titlePlaceholder') %>" maxlength="100" required>
        </div>
        
        <div class="form-group mt-2">
          <label class="form-label" data-i18n="descLabel"><%= __('descLabel') %></label>
          <textarea class="report-textarea" id="description" rows="5" data-i18n-placeholder="descPlaceholder" placeholder="<%= __('descPlaceholder') %>" maxlength="1000" required oninput="document.getElementById('descCount').textContent=this.value.length+' / 1000'"></textarea>
          <div style="text-align:right;font-size:0.8rem;color:var(--report-muted)" id="descCount">0 / 1000</div>
        </div>
        
        <div class="report-actions between">
          <button type="button" onclick="goStep(1)" class="report-btn report-btn-outline" data-i18n="backBtn"><%= __('backBtn') %></button>
          <button type="button" onclick="goStep(3)" class="report-btn report-btn-primary">
            <%= __('nextLocation') %>
            <svg style="width:20px;height:20px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>

      <!-- STEP 3: Location -->
      <div id="step3" class="report-card hidden stagger-2">
        <div class="report-card-title">
          <svg style="width:24px;height:24px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span data-i18n="locationTitle"><%= __('locationTitle') %></span>
        </div>
        
        <div style="display:flex;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap;align-items:center">
          <button type="button" onclick="autoLocation()" class="report-btn report-btn-primary report-btn-sm">
            <svg style="width:18px;height:18px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4"/></svg>
            <%= __('useMyGps') %>
          </button>
          <div class="text-sm text-muted" data-i18n="orClickMap"><%= __('orClickMap') %></div>
        </div>
        
        <div id="locLoading" class="hidden loading-center" style="margin-bottom:1rem"><div class="spinner"></div><span class="text-muted" style="margin-left:1rem" data-i18n="gettingLocation"><%= __('gettingLocation') %></span></div>
        <div id="map" style="height:350px;margin-bottom:1.5rem;border-radius:12px;border:1px solid var(--report-border)"></div>
        
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem">
          <div class="form-group"><label class="form-label" data-i18n="addressLabel"><%= __('addressLabel') %></label><input type="text" class="report-input" id="address" data-i18n-placeholder="addressPlaceholder" placeholder="<%= __('addressPlaceholder') %>"></div>
          <div class="form-group"><label class="form-label" data-i18n="landmarkLabel"><%= __('landmarkLabel') %></label><input type="text" class="report-input" id="landmark" data-i18n-placeholder="landmarkPlaceholder" placeholder="<%= __('landmarkPlaceholder') %>"></div>
        </div>
        
        <input type="hidden" id="lat"><input type="hidden" id="lng">
        <div class="text-danger text-sm hidden mt-1" id="locErr" data-i18n="errLocation"><%= __('errLocation') %></div>
        
        <div id="dupWarn" class="hidden info-card" style="margin-top:1.5rem;background:rgba(217, 119, 6, 0.1);border-color:rgba(217, 119, 6, 0.3)">
          <div class="info-card-title" style="color:#b45309">
            <svg style="width:20px;height:20px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            <strong data-i18n="dupWarn"><%= __('dupWarn') %></strong>
          </div>
          <a href="#" id="dupLink" style="color:var(--report-maroon);font-weight:600;text-decoration:underline" data-i18n="viewExisting"><%= __('viewExisting') %></a>
        </div>
        
        <div class="report-actions between" style="margin-top:2rem">
          <button type="button" onclick="goStep(2)" class="report-btn report-btn-outline" data-i18n="backBtn"><%= __('backBtn') %></button>
          
          <div style="display:flex;gap:1rem">
            <button type="button" onclick="saveOffline()" id="offlineBtn" class="report-btn report-btn-outline hidden">
              <svg style="width:20px;height:20px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>
              <%= __('saveOfflineBtn') %>
            </button>
            <button type="submit" id="submitBtn" class="report-btn report-btn-primary">
              <svg style="width:20px;height:20px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <%= __('submitComplaint') %>
            </button>
          </div>
        </div>
      </div>
    </form>

    <!-- How to Report Effectively Section -->
    <div class="info-card stagger-3">
      <div class="info-card-title">
        <svg style="width:24px;height:24px;color:var(--report-maroon)" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span data-i18n="howToReportEffectively"><%= __('howToReportEffectively') %></span>
      </div>
      <div class="info-list">
        <div class="info-item">
          <svg class="info-item-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <div class="info-item-text"><strong data-i18n="tipClearPhotosTitle"><%= __('tipClearPhotosTitle') %></strong> 
            <span data-i18n="tipClearPhotosDesc"><%= __('tipClearPhotosDesc') %></span>
          </div>
        </div>
        <div class="info-item">
          <svg class="info-item-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <div class="info-item-text"><strong data-i18n="tipAccurateLocationTitle"><%= __('tipAccurateLocationTitle') %></strong>
            <span data-i18n="tipAccurateLocationDesc"><%= __('tipAccurateLocationDesc') %></span>
          </div>
        </div>
        <div class="info-item">
          <svg class="info-item-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <div class="info-item-text"><strong data-i18n="tipBriefDescriptionTitle"><%= __('tipBriefDescriptionTitle') %></strong>
            <span data-i18n="tipBriefDescriptionDesc"><%= __('tipBriefDescriptionDesc') %></span>
          </div>
        </div>
        <div class="info-item">
          <svg class="info-item-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          <div class="info-item-text"><strong data-i18n="tipAvoidDuplicatesTitle"><%= __('tipAvoidDuplicatesTitle') %></strong>
            <span data-i18n="tipAvoidDuplicatesDesc"><%= __('tipAvoidDuplicatesDesc') %></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/scripts') %>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
if (!window.NIRVAAH?.Auth.isLoggedIn()) {
  window.location.href = '/login';
} else if (window.NIRVAAH.Auth.isAdmin()) {
  window.location.href = '/admin/dashboard';
}
if (!navigator.onLine) { document.getElementById('offlineBtn').classList.remove('hidden'); document.getElementById('submitBtn').style.display='none'; }
window.addEventListener('offline', () => { document.getElementById('offlineBtn').classList.remove('hidden'); document.getElementById('submitBtn').style.display='none'; });
window.addEventListener('online', () => { document.getElementById('offlineBtn').classList.add('hidden'); document.getElementById('submitBtn').style.display=''; });

// Drag & Drop
const dz = document.getElementById('dropzone');
dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('drag-over'); });
dz.addEventListener('dragleave', () => dz.classList.remove('drag-over'));
dz.addEventListener('drop', e => { e.preventDefault(); dz.classList.remove('drag-over'); handleImages(e.dataTransfer.files); });

let files = [], selCat = '', step = 1, map, marker;

function handleImages(f) {
  files = [...files, ...Array.from(f)].slice(0, 5);
  document.getElementById('imgErr').classList.add('hidden');
  document.getElementById('previewGrid').innerHTML = files.map((f,i) =>
    `<div class="preview-item"><img src="${URL.createObjectURL(f)}" alt="Preview"><button type="button" title="Remove image" onclick="files.splice(${i},1);document.getElementById('previewGrid').innerHTML='';handleImages(new DataTransfer().files)" class="preview-remove"><svg style="width:16px;height:16px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button></div>`
  ).join('');
  
  // AI suggestion (Removed emojis from mapping array for clean UI)
  const fn = f[0]?.name?.toLowerCase() || '';
  const match = [['pothole','Pothole'],['garbage','Garbage'],['water','Water Leak'],['electric','Electricity'],['road','Road Damage'],['light','Street Light'],['tree','Tree Hazard']].find(([k]) => fn.includes(k));
  if (match) { 
    window._aiVal = ['pothole','garbage','water_leakage','electricity','road_damage','street_light','tree_hazard'][['pothole','garbage','water','electric','road','light','tree'].indexOf(match[0])]; 
    document.getElementById('aiCat').textContent = match[1]; 
    document.getElementById('aiBox').classList.remove('hidden'); 
  }
}

function acceptAI() { selectCat(window._aiVal); document.getElementById('aiBox').classList.add('hidden'); }

function selectCat(cat) {
  selCat = cat; document.getElementById('category').value = cat;
  document.querySelectorAll('.category-chip').forEach(c => c.classList.remove('selected'));
  document.querySelector(`[data-cat="${cat}"]`)?.classList.add('selected');
  document.getElementById('catErr').classList.add('hidden');
}

function goStep(n) {
  if (n > step) {
    if (step === 1 && !files.length) { document.getElementById('imgErr').classList.remove('hidden'); return; }
    if (step === 1 && !selCat) { document.getElementById('catErr').classList.remove('hidden'); return; }
    if (step === 2 && !document.getElementById('title').value.trim()) { alert('Please enter a title.'); return; }
  }
  
  document.getElementById(`step${step}`).classList.add('hidden');
  document.getElementById(`step${n}`).classList.remove('hidden');
  
  // Update Stepper Visuals
  ['ind1','ind2','ind3'].forEach((id,i) => {
    const item = document.getElementById(id);
    const isPast = (i + 1) < n;
    const isActive = (i + 1) === n;
    
    item.classList.toggle('active', isActive);
    item.classList.toggle('completed', isPast);
    
    const circle = item.querySelector('.stepper-circle');
    if (circle) {
      if (isPast) {
        circle.innerHTML = `<svg style="width:24px;height:24px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>`;
      } else {
        circle.textContent = i + 1;
      }
    }
  });
  
  const progress = document.getElementById('stepProgressFill');
  if (progress) progress.style.width = `${((n - 1) / 2) * 100}%`;

  step = n;
  if (n === 3) initMap();
}

function initMap() {
  if (map) return;
  map = L.map('map').setView([20.5937, 78.9629], 5);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(map);
  map.on('click', e => setLocation(e.latlng.lat, e.latlng.lng));
}

async function setLocation(lat, lng) {
  document.getElementById('lat').value = lat; document.getElementById('lng').value = lng;
  document.getElementById('locErr').classList.add('hidden');
  if (marker) map.removeLayer(marker);
  marker = L.marker([lat, lng], { icon: L.divIcon({ className:'', html:`<div style="width:18px;height:18px;border-radius:50%;background:var(--report-maroon);border:3px solid #fff;box-shadow:0 4px 10px rgba(0,0,0,.3)"></div>`, iconSize:[18,18], iconAnchor:[9,9] }) }).addTo(map).bindPopup('Issue Location').openPopup();
  map.setView([lat, lng], 15);

  // Reverse Geocoding via Nominatim
  const addressInput = document.getElementById('address');
  const originalPlaceholder = addressInput.placeholder;
  try {
    addressInput.placeholder = 'Fetching address...';
    const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`);
    if (response.ok) {
        const data = await response.json();
        if (data && data.display_name) {
            addressInput.value = data.display_name;
        }
    }
    addressInput.placeholder = originalPlaceholder;
  } catch (err) {
    console.error('Reverse geocoding failed', err);
    addressInput.placeholder = originalPlaceholder;
  }
}

function autoLocation() {
  document.getElementById('locLoading').classList.remove('hidden');
  navigator.geolocation.getCurrentPosition(
    p => { document.getElementById('locLoading').classList.add('hidden'); setLocation(p.coords.latitude, p.coords.longitude); },
    () => { document.getElementById('locLoading').classList.add('hidden'); alert('Could not get location. Click on the map.'); },
    { enableHighAccuracy: true, timeout: 10000 }
  );
}

async function saveOffline() {
  if (!files.length) { alert('Attach at least one image before saving offline.'); return; }
  const lat = document.getElementById('lat').value; if (!lat) { alert('Select a location first.'); return; }
  const token = localStorage.getItem('nirvaah_token');
  await (typeof globalThis !== 'undefined' ? globalThis : self).NirvaahDB.queueComplaint({ 
    title: document.getElementById('title').value, 
    description: document.getElementById('description').value, 
    category: selCat, 
    lat, 
    lng: document.getElementById('lng').value, 
    address: document.getElementById('address').value,
    images: files
  }, token);
  if ('serviceWorker' in navigator && 'SyncManager' in window) { const r = await navigator.serviceWorker.ready; await r.sync.register('sync-pending-complaints'); }
  showToast('Saved Offline', 'Will sync when you reconnect.', 'info');
  setTimeout(() => location.href = '/my-complaints', 1500);
}

document.getElementById('reportForm').addEventListener('submit', async e => {
  e.preventDefault();
  const lat = document.getElementById('lat').value;
  if (!files.length) { goStep(1); document.getElementById('imgErr').classList.remove('hidden'); return; }
  if (!lat) { document.getElementById('locErr').classList.remove('hidden'); return; }
  const btn = document.getElementById('submitBtn'); 
  const originalBtnHtml = btn.innerHTML;
  btn.disabled=true; btn.innerHTML='Submitting...';
  const fd = new FormData();
  ['title','description','category','lat','lng','address','landmark'].forEach(k => { const el=document.getElementById(k); if(el?.value) fd.append(k, el.value); });
  files.forEach(f => fd.append('images', f));
  try {
    const data = await window.NIRVAAH.Complaints.create(fd);
    if (data.duplicate?.detected) { document.getElementById('dupWarn').classList.remove('hidden'); document.getElementById('dupLink').href=`/complaint?id=${data.duplicate.existingId}`; }
    showToast('Submitted!', 'Complaint reported successfully.', 'success');
    setTimeout(() => location.href = '/my-complaints', 1800);
  } catch(err) {
    showToast('Error', err.message||'Failed to submit.', 'error');
    btn.disabled=false; btn.innerHTML=originalBtnHtml;
  }
});
</script>
</body></html>
