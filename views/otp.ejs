<%- include('partials/head') %>
<div class="auth-page">
  <div class="auth-orb auth-orb-1"></div>
  <div class="auth-orb auth-orb-2"></div>

  <div class="auth-card">
    <div class="auth-logo">
      <h1 class="auth-title">
        <%= __('otpVerificationTitle') || 'OTP Verification' %>
      </h1>
      <p class="auth-subtitle">
        <%= __('otpVerificationSub') || 'Enter the code sent to your email' %>
      </p>
    </div>

    <form id="otpForm" novalidate>
      <div class="form-group">
        <label class="form-label"><%= __('otpCode') || 'OTP code' %></label>
        <input
          type="text"
          class="form-control"
          id="otp"
          placeholder="Enter 6-digit code"
          maxlength="6"
          required
        />
      </div>

      <div
        class="text-danger text-sm mb-2 hidden text-center"
        id="otpError"
      ></div>
      <div
        class="text-success text-sm mb-2 hidden text-center"
        id="otpMessage"
      ></div>

      <button
        type="submit"
        class="btn btn-primary btn-lg btn-block"
        id="verifyOtpBtn"
      >
        <span data-i18n="verifyBtn"><%= __('verifyBtn') || 'Verify' %></span>
      </button>

      <button
        type="button"
        class="btn btn-outline btn-lg btn-block mt-2"
        id="resendOtpBtn"
      >
        <span data-i18n="resendOtpBtn"
          ><%= __('resendOtpBtn') || 'Resend OTP' %></span
        >
      </button>
    </form>

    <p class="text-center text-sm text-muted mt-2">
      <a href="/login"><%= __('backToLogin') || 'Back to login' %></a>
    </p>
  </div>
</div>

<script src="/js/api.js"></script>
<script>
  const urlParams = new URLSearchParams(window.location.search);
  let sessionId = urlParams.get("sessionId");
  const userEmail = decodeURIComponent(urlParams.get("email") || "");

  const otpError = document.getElementById("otpError");
  const otpMessage = document.getElementById("otpMessage");

  const showError = (msg) => {
    otpError.textContent = msg;
    otpError.classList.remove("hidden");
    otpMessage.classList.add("hidden");
  };

  const showMessage = (msg) => {
    otpMessage.textContent = msg;
    otpMessage.classList.remove("hidden");
    otpError.classList.add("hidden");
  };

  document.getElementById("otpForm").addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!sessionId) {
      return showError("Missing OTP session. Please login again.");
    }

    const otpValue = document.getElementById("otp").value.trim();
    if (!otpValue || !/^\d{6}$/.test(otpValue)) {
      return showError("Please enter a 6-digit OTP code.");
    }

    const btn = document.getElementById("verifyOtpBtn");
    btn.disabled = true;

    try {
      const data = await window.NIRVAAH.Auth.verifyOtp(sessionId, otpValue);
      showMessage("OTP verified. Redirecting...");
      setTimeout(() => {
        window.location.href = window.NIRVAAH.Auth.isAdmin()
          ? "/admin/dashboard"
          : "/dashboard";
      }, 700);
    } catch (err) {
      if (err.data && err.data.expired) {
        showError("OTP expired. Please request a new code.");
      } else {
        showError(err.message || "OTP verification failed.");
      }
      btn.disabled = false;
    }
  });

  document
    .getElementById("resendOtpBtn")
    .addEventListener("click", async () => {
      if (!sessionId) {
        return showError("Missing OTP session. Please login again.");
      }

      try {
        const data = await window.NIRVAAH.Auth.resendOtp(sessionId);
        sessionId = data.sessionId || sessionId;
        showMessage("New OTP sent to " + userEmail + ".");
      } catch (err) {
        showError(err.message || "Could not resend OTP.");
      }
    });
</script>
