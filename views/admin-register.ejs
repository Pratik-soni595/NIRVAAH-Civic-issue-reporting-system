<%- include('partials/head') %>
<div class="auth-page">
  <div class="auth-orb auth-orb-1"></div>
  <div class="auth-orb auth-orb-2"></div>

  <div class="auth-card" style="max-width:480px">
    <div class="auth-logo">
      <div class="auth-logo-icon" style="display:inline-flex;align-items:center;justify-content:center;">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <h1 class="auth-title">Admin Register</h1>
      <p class="auth-subtitle">Create a new administrator account</p>
    </div>

    <form id="registerForm" novalidate>
      <div class="form-group">
        <label class="form-label" data-i18n="fullName"><%= __('fullName') %></label>
        <input type="text" class="form-control" id="name" data-i18n-placeholder="fullNamePlaceholder" placeholder="<%= __('fullNamePlaceholder') %>" required>
      </div>
      <div class="form-group">
        <label class="form-label" data-i18n="emailAddress"><%= __('emailAddress') %></label>
        <input type="email" class="form-control" id="email" data-i18n-placeholder="emailPlaceholder" placeholder="<%= __('emailPlaceholder') %>" required>
      </div>
      <div class="form-group" style="display:flex;gap:1rem;">
        <div style="flex:1">
          <label class="form-label" data-i18n="wardNoLabel"><%= __('wardNoLabel') || 'Ward Number' %></label>
          <input type="text" class="form-control" id="wardNo" data-i18n-placeholder="wardNoPlaceholder" placeholder="<%= __('wardNoPlaceholder') || 'e.g. 12' %>" required>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" data-i18n="passwordLabel"><%= __('passwordLabel') %></label>
        <div style="position:relative">
          <input type="password" class="form-control" id="password" data-i18n-placeholder="min6Chars" placeholder="<%= __('min6Chars') %>" required oninput="checkStrength(this.value)">
          <button type="button" class="toggle-pwd" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted);cursor:pointer;line-height:1;padding:0.2rem;" aria-label="Show password">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
        <div style="margin-top:0.5rem;display:flex;gap:4px">
          <div id="s1" style="height:3px;flex:1;border-radius:2px;background:var(--border);transition:.3s"></div>
          <div id="s2" style="height:3px;flex:1;border-radius:2px;background:var(--border);transition:.3s"></div>
          <div id="s3" style="height:3px;flex:1;border-radius:2px;background:var(--border);transition:.3s"></div>
          <div id="s4" style="height:3px;flex:1;border-radius:2px;background:var(--border);transition:.3s"></div>
        </div>
        <div id="strengthLabel" class="text-sm text-muted mt-1"></div>
      </div>
      <div class="form-group">
        <label class="form-label"><%= __('confirmPassword') %></label>
        <input type="password" class="form-control" id="confirmPassword" data-i18n-placeholder="repeatPassword" placeholder="<%= __('repeatPassword') %>" required>
      </div>

      <div class="form-group" id="adminSecretBox" style="background:rgba(239, 68, 68, 0.05);padding:1rem;border-radius:var(--radius-sm);border:1px solid rgba(239, 68, 68, 0.2)">
        <label class="form-label" style="color:var(--danger)" data-i18n="adminSecretKey"><%= __('adminSecretKey') %></label>
        <input type="password" class="form-control" id="adminSecret" data-i18n-placeholder="adminSecretPlaceholder" placeholder="<%= __('adminSecretPlaceholder') %>" required>
        <div class="text-xs text-muted mt-1">Required for Admin registration</div>
      </div>

      <div class="form-group" style="display:flex;align-items:flex-start;gap:0.5rem">
        <input type="checkbox" id="terms" style="accent-color:var(--primary);width:16px;height:16px;margin-top:2px;flex-shrink:0">
        <label for="terms" class="text-sm" style="text-transform:none;letter-spacing:normal;font-weight:400;color:var(--text-muted)">
          <%= __('iAgreeToText') %> <a href="#" class="text-primary" data-i18n="termsOfService"><%= __('termsOfService') %></a> <%= __('andText') %> <a href="#" class="text-primary" data-i18n="privacyPolicy"><%= __('privacyPolicy') %></a>
        </label>
      </div>

      <div class="text-danger text-sm mb-2 hidden text-center" id="regError"></div>

      <button type="submit" class="btn btn-primary btn-lg btn-block" id="regBtn" data-i18n="createAccountBtn"><%= __('createAccountBtn') %></button>
    </form>

    <div class="divider"></div>
    <p class="text-center text-sm text-muted">
      Already admin? <a href="/admin/login" class="text-primary fw-bold">Sign in</a><br>
      <span style="display:inline-block;margin-top:0.5rem;">Citizen user? <a href="/register" class="text-primary fw-bold">Register here</a></span>
    </p>
  </div>
</div>

<div class="toast-container" id="toastContainer"></div>
<script src="/js/api.js"></script>
<script>
if (window.NIRVAAH?.Auth.isLoggedIn()) {
  const u = window.NIRVAAH.getUser();
  if (u?.accountType === 'admin' || u?.role === 'admin') {
    window.location.href = '/admin/dashboard';
  } else {
    window.location.href = '/dashboard';
  }
}

function checkStrength(val) {
  let score = 0;
  if (val.length >= 6) score++;
  if (val.length >= 10) score++;
  if (/[A-Z]/.test(val) && /[a-z]/.test(val)) score++;
  if (/\d/.test(val) && /[^a-zA-Z\d]/.test(val)) score++;
  const colors = ['','#ef4444','#f59e0b','#6366f1','#10b981'];
  const labels = ['','<%= __("pwdWeak") %>','<%= __("pwdFair") %>','<%= __("pwdGood") %>','<%= __("pwdStrong") %>'];
  for (let i=1;i<=4;i++) document.getElementById(`s${i}`).style.background = i<=score?colors[score]:'var(--border)';
  const lbl = document.getElementById('strengthLabel');
  lbl.textContent = val.length?labels[score]:'';
  lbl.style.color = colors[score]||'var(--text-muted)';
}

document.querySelectorAll('.toggle-pwd').forEach(btn => {
  btn.addEventListener('click', function() {
    const input = this.previousElementSibling;
    const showing = input.type === 'text';
    input.type = showing ? 'password' : 'text';

    this.innerHTML = showing ?
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>' :
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';

    this.setAttribute('aria-label', showing ? 'Show password' : 'Hide password');
  });
});

document.getElementById('registerForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const name = document.getElementById('name').value.trim();
  const email = document.getElementById('email').value.trim();
  const password = document.getElementById('password').value;
  const confirm = document.getElementById('confirmPassword').value;
  const terms = document.getElementById('terms').checked;
  const wardNo = document.getElementById('wardNo').value.trim();
  const adminSecret = document.getElementById('adminSecret').value.trim();
  const role = 'admin';
  const errEl = document.getElementById('regError');
  errEl.classList.add('hidden');

  if (!name||!email||!password||!wardNo||!adminSecret) { errEl.textContent='<%= __("allFieldsReq") %>'; errEl.classList.remove('hidden'); return; }
  if (password !== confirm) { errEl.textContent='<%= __("pwdsNotMatch") %>'; errEl.classList.remove('hidden'); return; }
  if (password.length < 6) { errEl.textContent='<%= __("pwdMin6Chars") %>'; errEl.classList.remove('hidden'); return; }
  if (!terms) { errEl.textContent='<%= __("acceptTermsReq") %>'; errEl.classList.remove('hidden'); return; }

  const btn = document.getElementById('regBtn');
  btn.disabled=true; btn.textContent='<%= __("creatingAccountText") %>';

  try {
    const data = await window.NIRVAAH.Auth.register(name, email, password, role, adminSecret, wardNo, "", "");
    
    // Check if created account is actually admin
    if (data.accountType !== 'admin' && data.user?.role !== 'admin') {
      window.NIRVAAH.Auth.logout();
      throw new Error("Admin registration failed. The account was created as a citizen instead (Invalid Admin Secret?).");
    }

    btn.textContent='<%= __("accountCreatedSuccess") %>';
    setTimeout(() => window.location.href = '/admin/dashboard', 800);
  } catch (err) {
    errEl.textContent = err.message||'<%= __("registrationFailed") %>';
    errEl.classList.remove('hidden');
    btn.disabled=false; btn.textContent='<%= __("createAccountBtn") %>';
  }
});
</script>
</body></html>
