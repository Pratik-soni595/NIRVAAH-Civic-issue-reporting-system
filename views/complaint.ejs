<%- include('partials/head') %>
<%- include('partials/navbar', {navPage}) %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<link rel="stylesheet" href="/css/detail-page.css">

<div class="page-wrapper">
  <div class="detail-page">
    <div class="detail-container">
      <div id="loadingState" class="detail-loading">
        <div class="detail-spinner"></div>
        <div class="detail-loading-text"><%= __('loading') || 'Loading...' %></div>
      </div>
      <div id="content" class="hidden"></div>
    </div>
  </div>
</div>

<%- include('partials/scripts') %>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
if (!window.NIRVAAH?.Auth.isLoggedIn()) {
  window.location.href = '/login';
} else if (window.NIRVAAH.Auth.isAdmin()) {
  window.location.href = '/admin/dashboard';
}
const me = window.NIRVAAH.getUser();
const id = new URLSearchParams(location.search).get('id');
if (!id) location.href = '/my-complaints';

const statusColors = { pending: '#991B1B', in_progress: '#9A6700', resolved: '#4A3B8A' };
const statusLabels = {
  pending:     '<%= __("pending") %>',
  in_progress: '<%= __("inProgress") %>',
  resolved:    '<%= __("resolved") %>'
};

function fmtDate(d) {
  const dt = new Date(d);
  return dt.toLocaleDateString('en-IN', { day:'2-digit', month:'2-digit', year:'numeric' })
    + ', ' + dt.toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit', second:'2-digit' });
}

function catLabel(c) { return (c||'').replace(/_/g, ' '); }

async function load() {
  try {
    const data = await window.NIRVAAH.Complaints.getById(id);
    const c = data.complaint;
    document.title = `${c.title} – NIRVAAH`;
    document.getElementById('loadingState').classList.add('hidden');
    const div = document.getElementById('content');
    div.classList.remove('hidden');
    const hasVoted = c.votes?.some(v => (v._id || v) === me?.id);
    const isOwner = me && (c.user?._id === me.id);
    const initial = c.user?.name?.[0]?.toUpperCase() || '?';
    const sColor = statusColors[c.status] || '#7A1C1C';

    div.innerHTML = `
      <!-- Breadcrumb -->
      <div class="detail-breadcrumb">
        <a href="/dashboard"><%= __('dashboard') %></a>
        <span class="bc-sep">›</span>
        <a href="/my-complaints"><%= __('reportsLink') %></a>
        <span class="bc-sep">›</span>
        <span class="bc-current">${c.title}</span>
      </div>

      <div class="detail-grid">
        <!-- ═══ LEFT COLUMN ═══ -->
        <div class="detail-left">

          <!-- Image -->
          ${c.images?.length ? `
          <div class="detail-image-wrap">
            <img id="mainImg" src="${c.images[0].url}" alt="${c.title}" class="detail-main-image">
            ${c.images.length > 1 ? `
            <div class="detail-thumbnails">
              ${c.images.map((img, i) => `<img src="${img.url}" class="detail-thumb ${i===0?'active':''}" onclick="switchImg(this,'${img.url}')" loading="lazy">`).join('')}
            </div>` : ''}
          </div>
          ` : `
          <div class="detail-no-image">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/>
            </svg>
          </div>
          `}

          <!-- Title + Actions Row -->
          <div class="detail-title-row">
            <h1 class="detail-title">${c.title}</h1>
            <div class="detail-inline-actions">
              <div class="detail-status-inline">
                <span class="detail-status-dot ${c.status}"></span>
                <span class="detail-status-label">${statusLabels[c.status] || c.status}</span>
              </div>
              <div class="detail-vote-count-inline">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                <span id="vcInline">${c.voteCount || 0}</span>
              </div>
              ${!isOwner ? `
              <button id="voteBtn" onclick="toggleVote()" class="detail-vote-btn ${hasVoted ? 'voted' : 'not-voted'}">
                ${hasVoted ? '<%= __("voted") %>' : '+ Vote'}
              </button>
              ` : ''}
            </div>
          </div>

          <!-- Reporter Meta -->
          <div class="detail-meta">
            <div class="detail-meta-avatar">${initial}</div>
            <span class="detail-meta-name">${c.user?.name || '<%= __("unknownUser") %>'}</span>
            <span class="detail-meta-time">${fmtDate(c.createdAt)}</span>
          </div>

          <!-- Badges -->
          <div class="detail-badges">
            <span class="detail-badge detail-badge-${c.priority}">${c.priority}</span>
            <span class="detail-badge detail-badge-category">${catLabel(c.category)}</span>
            ${c.isDuplicate ? `<span class="detail-badge detail-badge-duplicate"><%= __('duplicateFlagged') %></span>` : ''}
          </div>

          <!-- Description — plain text -->
          <div class="detail-desc-label" data-i18n="descriptionHeading"><%= __('descriptionHeading') %></div>
          <div class="detail-desc-text">${c.description}</div>

          <!-- Admin Note -->
          ${c.adminNote ? `
          <div class="detail-admin-note">
            <div class="detail-admin-note-label"><%= __('adminNoteTitle') %></div>
            <div class="detail-admin-note-text">${c.adminNote}</div>
          </div>
          ` : ''}

          <!-- Status Timeline -->
          ${c.statusHistory?.length ? `
          <div class="detail-timeline-label" data-i18n="statusTimeline"><%= __('statusTimeline') %></div>
          ${c.statusHistory.map(h => `
          <div class="timeline-item">
            <div class="timeline-dot" style="background:${statusColors[h.status]||'#7A1C1C'}"></div>
            <div>
              <div class="tl-status">${statusLabels[h.status]||h.status}</div>
              ${h.note ? `<div class="tl-note">${h.note}</div>` : ''}
              <div class="tl-date">${new Date(h.timestamp).toLocaleString()}</div>
            </div>
          </div>
          `).join('')}
          ` : ''}

          <!-- TRS Resolution Evidence (public view) -->
          <div id="resolutionEvidenceSection"></div>

        </div>

        <!-- ═══ RIGHT COLUMN ═══ -->
        <div class="detail-right">

          <!-- Map -->
          <div class="detail-map-wrap">
            <div id="detailMap" class="detail-map"></div>
          </div>

          <!-- Location — plain text -->
          <div class="detail-location">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <span>${c.location?.address || '<%= __("noAddress") %>'} ${c.location?.landmark ? `· <%= __("nearLandmark") %> ${c.location.landmark}` : ''}</span>
          </div>

          <!-- Status Summary -->
          <div class="detail-status-summary">
            <div class="detail-status-summary-dot ${c.status}"></div>
            <div>
              <div class="detail-status-summary-text">${statusLabels[c.status] || c.status}</div>
              <div class="detail-status-summary-sub">${c.statusHistory?.length ? 'Updated ' + new Date(c.statusHistory[c.statusHistory.length-1].timestamp).toLocaleDateString() : 'Reported ' + new Date(c.createdAt).toLocaleDateString()}</div>
            </div>
          </div>

        </div>
      </div>
    `;

    // Map
    if (c.location?.coordinates) {
      const [lng, lat] = c.location.coordinates;
      const dm = L.map('detailMap', { scrollWheelZoom: false }).setView([lat,lng], 15);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OSM' }).addTo(dm);
      L.marker([lat,lng], {
        icon: L.divIcon({ className:'', html:`<div style="width:14px;height:14px;border-radius:50%;background:${sColor};border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.4)"></div>`, iconSize:[14,14], iconAnchor:[7,7] })
      }).addTo(dm).bindPopup(c.title).openPopup();
    }
    return { status: c.status, isOwner }; // pass status and owner to caller
  } catch(err) {
    document.getElementById('loadingState').innerHTML = `
      <div class="detail-error">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
        <div class="detail-error-title"><%= __('notFound') %></div>
        <a href="/my-complaints" class="detail-error-btn"><%= __('backBtn') %></a>
      </div>`;
  }
}

function switchImg(thumb, url) {
  document.getElementById('mainImg').src = url;
  document.querySelectorAll('.detail-thumb').forEach(t => t.classList.remove('active'));
  thumb.classList.add('active');
}

async function toggleVote() {
  try {
    const data = await window.NIRVAAH.Complaints.vote(id);
    document.getElementById('vcInline').textContent = data.voteCount;
    const btn = document.getElementById('voteBtn');
    btn.className = `detail-vote-btn ${data.voted ? 'voted' : 'not-voted'}`;
    btn.textContent = data.voted ? '<%= __("voted") %>' : '+ Vote';
    showToast(data.voted ? '<%= __("voted") %>!' : '<%= __("voteRemoved") %>', `${data.voteCount} <%= __("votesTitle") %>.`, 'success');
  } catch(e) { showToast('Error', e.message, 'error'); }
}

// ── TRS: load public resolution evidence after main complaint renders ─────────
async function loadResolutionEvidence(complaintStatus) {
  if (complaintStatus !== 'resolved') return false;
  const section = document.getElementById('resolutionEvidenceSection');
  if (!section) return false;
  try {
    const resp = await fetch(`/api/complaints/${id}/resolution/public`);
    if (!resp.ok) return false; // no evidence yet — silently skip
    const d = await resp.json();
    if (!d.success || !d.resolution) return false;
    const ev = d.resolution;
    renderEvidencePanel(section, ev, d.resolvedAt);
    return true;
  } catch(e) { return false; /* non-critical — don't break the page */ }
}

function renderEvidencePanel(container, ev, resolvedAt) {
  const isSusp = ev.isSuspicious;
  const integ  = ev.integrityStatus;

  // Integrity badge
  let integrityHtml = '';
  if (integ === 'VERIFIED') {
    integrityHtml = `<div class="trs-ev-badge trs-ev-ok">✅ Location Verified — within ${ev.distanceFromOriginM}m of site</div>`;
  } else if (integ === 'UNDER_REVIEW') {
    integrityHtml = `<div class="trs-ev-badge trs-ev-warn">⚠️ Under Supervisory Review — resolution location was ${ev.distanceFromOriginM}m from site</div>`;
  } else if (integ === 'SUSPICIOUS_APPROVED') {
    integrityHtml = `<div class="trs-ev-badge trs-ev-ok">✅ Supervisor Verified — location discrepancy reviewed and approved</div>`;
  } else if (integ === 'SUSPICIOUS_REJECTED') {
    integrityHtml = `<div class="trs-ev-badge trs-ev-err">🔴 Resolution Disputed — complaint reopened for re-investigation</div>`;
  }

  container.innerHTML = `
    <style>
      .trs-ev-section{margin-top:1.5rem;border-top:1px solid var(--border);padding-top:1.5rem}
      .trs-ev-title{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted);margin-bottom:.75rem;display:flex;align-items:center;gap:.4rem}
      .trs-ev-img{width:100%;border-radius:8px;margin-bottom:.75rem;border:1px solid var(--border-light)}
      .trs-ev-row{display:flex;justify-content:space-between;align-items:center;font-size:.82rem;padding:.45rem 0;border-bottom:1px solid var(--border-light)}
      .trs-ev-row:last-of-type{border-bottom:none}
      .trs-ev-lbl{color:var(--text-muted)}
      .trs-ev-val{font-weight:600;text-align:right;word-break:break-all;max-width:60%}
      .trs-ev-badge{font-size:.8rem;font-weight:600;padding:.5rem .85rem;border-radius:6px;margin-bottom:.75rem;display:flex;align-items:center;gap:.4rem}
      .trs-ev-ok{background:rgba(74,59,138,.08);color:#4A3B8A;border:1px solid rgba(74,59,138,.2)}
      .trs-ev-warn{background:rgba(154,103,0,.08);color:#9A6700;border:1px solid rgba(154,103,0,.2)}
      .trs-ev-err{background:rgba(153,27,27,.08);color:#991B1B;border:1px solid rgba(153,27,27,.2)}
      .trs-ev-map{height:160px;border-radius:8px;overflow:hidden;margin-bottom:.75rem;border:1px solid var(--border-light)}
      .trs-ev-hash{font-size:.7rem;font-family:monospace;word-break:break-all;color:var(--text-muted)}
      .trs-ev-lock{display:flex;align-items:center;gap:.5rem;font-size:.78rem;color:var(--text-muted);margin-top:.75rem}
    </style>
    <div class="trs-ev-section">
      <div class="trs-ev-title">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Resolution Evidence
      </div>
      ${integrityHtml}
      ${ev.imageUrl ? `<img src="${ev.imageUrl}" class="trs-ev-img" alt="Resolution evidence photo">` : ''}
      <div class="trs-ev-row"><span class="trs-ev-lbl">Resolved On</span><span class="trs-ev-val">${new Date(resolvedAt).toLocaleString('en-IN')}</span></div>
      <div class="trs-ev-row"><span class="trs-ev-lbl">🔒 Timestamp</span><span class="trs-ev-val">Server-verified</span></div>
      <div class="trs-ev-row"><span class="trs-ev-lbl">Distance from Site</span><span class="trs-ev-val">${ev.distanceFromOriginM != null ? ev.distanceFromOriginM + 'm' : 'N/A'}</span></div>
      <div class="trs-ev-row"><span class="trs-ev-lbl">Location</span><span class="trs-ev-val">${ev.vicinity}</span></div>
      ${ev.notes ? `<div class="trs-ev-row"><span class="trs-ev-lbl">Resolution Note</span><span class="trs-ev-val">${ev.notes}</span></div>` : ''}
      ${ev.imageHash ? `<div style="margin-top:.6rem"><div class="trs-ev-lbl" style="font-size:.75rem;margin-bottom:.2rem">Image Integrity Hash</div><div class="trs-ev-hash">${ev.imageHash}</div></div>` : ''}
      ${ev.originCoordinates ? `<div id="trsEvMap" class="trs-ev-map" style="margin-top:.75rem"></div>` : ''}
      <div class="trs-ev-lock">
        <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Evidence is immutable — cryptographically sealed at submission time
      </div>
    </div>`;

  // Lazy-load resolution map if origin coords exist
  if (ev.originCoordinates && typeof L !== 'undefined') {
    const [oLng, oLat] = ev.originCoordinates;
    setTimeout(() => {
      const m = L.map('trsEvMap', { scrollWheelZoom: false, zoomControl: false }).setView([oLat, oLng], 16);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(m);
      // Complaint site pin (red)
      L.marker([oLat, oLng], {
        icon: L.divIcon({ className:'', html:`<div style="width:12px;height:12px;border-radius:50%;background:#991B1B;border:2px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,.4)"></div>`, iconSize:[12,12], iconAnchor:[6,6] })
      }).addTo(m).bindPopup('<b>📍 Complaint Site</b>');
    }, 200);
  }
}

// Single entry-point: render complaint then lazy-load TRS evidence panel
async function loadWithEvidence() {
  const result = await load();
  if (result.status === 'resolved') {
    setTimeout(async () => {
      const hasEvidence = await loadResolutionEvidence('resolved');
      if (hasEvidence && result.isOwner) {
        loadFeedbackCard();
      }
    }, 300);
  }
}

// ── Citizen Feedback Logic ──────────────────────────────────────────────
const escapeHTML = (str) => String(str||'').replace(/[&<>'"]/g, tag => ({
  '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;'
}[tag] || tag));

let currentRating = 0;

async function loadFeedbackCard() {
  const rightCol = document.querySelector('.detail-right');
  if (!rightCol) return;
  
  const container = document.createElement('div');
  container.id = 'feedbackContainer';
  rightCol.appendChild(container);

  try {
    const res = await window.NIRVAAH.Complaints.getFeedback(id);
    if (res && res.success && res.feedback) {
      renderFeedbackSummary(container, res.feedback);
    }
  } catch (e) {
    if (e.status === 404) {
      renderFeedbackForm(container);
    }
  }
}

function renderFeedbackSummary(container, fb) {
  container.innerHTML = `
    <div class="detail-feedback-card">
      <div class="detail-feedback-title">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.514"></path></svg>
        Citizen Feedback
      </div>
      <div class="detail-feedback-subtitle">Thank you for sharing your experience.</div>
      <div class="detail-feedback-summary-row">
        <span class="detail-feedback-summary-lbl">Rating</span>
        <span class="detail-feedback-rating-display">${'★'.repeat(fb.rating)}${'☆'.repeat(5 - fb.rating)}</span>
      </div>
      <div class="detail-feedback-summary-row">
        <span class="detail-feedback-summary-lbl">Satisfied?</span>
        <span class="detail-feedback-summary-val">${fb.isSatisfied ? 'Yes, issue fully resolved' : 'No, needs more work'}</span>
      </div>
      ${fb.comment ? `
      <div class="detail-feedback-summary-row" style="flex-direction:column; align-items:flex-start; margin-top:6px; border-top:1px solid #EDE4D8; padding-top:6px;">
        <span class="detail-feedback-summary-lbl">Comment</span>
        <span class="detail-feedback-summary-val" style="margin-top:4px; max-width:100%; text-align:left; font-weight:normal; font-size:0.8rem">${escapeHTML(fb.comment)}</span>
      </div>` : ''}
    </div>
  `;
}

function renderFeedbackForm(container) {
  container.innerHTML = `
    <div class="detail-feedback-card">
      <div class="detail-feedback-title">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path></svg>
        Rate this Resolution
      </div>
      <div class="detail-feedback-subtitle">As the reporter, please let us know how we did.</div>
      
      <div class="detail-feedback-group">
        <label class="detail-feedback-label">Your Rating (1-5)</label>
        <div class="detail-feedback-stars" id="fbStars">
          <span class="detail-feedback-star" data-val="1">★</span>
          <span class="detail-feedback-star" data-val="2">★</span>
          <span class="detail-feedback-star" data-val="3">★</span>
          <span class="detail-feedback-star" data-val="4">★</span>
          <span class="detail-feedback-star" data-val="5">★</span>
        </div>
      </div>

      <div class="detail-feedback-group">
        <label class="detail-feedback-label">Are you satisfied with the result?</label>
        <div class="detail-feedback-toggle">
          <label><input type="radio" name="fbSatisfied" value="true" checked> Yes</label>
          <label><input type="radio" name="fbSatisfied" value="false"> No</label>
        </div>
      </div>

      <div class="detail-feedback-group">
        <label class="detail-feedback-label">Additional Comments (Optional)</label>
        <textarea id="fbComment" class="detail-feedback-input" rows="2" placeholder="Tell us more about your experience..."></textarea>
      </div>

      <button id="fbSubmitBtn" class="detail-feedback-submit" onclick="submitFeedbackForm()">Submit Feedback</button>
    </div>
  `;

  const stars = document.querySelectorAll('.detail-feedback-star');
  stars.forEach(s => {
    s.addEventListener('mouseover', function() {
      const val = parseInt(this.dataset.val);
      stars.forEach(st => {
        if (parseInt(st.dataset.val) <= val) st.style.color = '#D4A373';
        else st.style.color = '#DDD0C0';
      });
    });
    s.addEventListener('mouseout', function() {
      stars.forEach(st => {
        if (parseInt(st.dataset.val) <= currentRating) st.style.color = '#D4A373';
        else st.style.color = '#DDD0C0';
      });
    });
    s.addEventListener('click', function() {
      currentRating = parseInt(this.dataset.val);
      stars.forEach(st => {
        if (parseInt(st.dataset.val) <= currentRating) {
          st.classList.add('selected');
          st.style.color = '#D4A373';
        } else {
          st.classList.remove('selected');
          st.style.color = '#DDD0C0';
        }
      });
    });
  });
}

async function submitFeedbackForm() {
  if (currentRating === 0) {
    showToast('Error', 'Please select a rating from 1 to 5 stars.', 'error');
    return;
  }
  const btn = document.getElementById('fbSubmitBtn');
  btn.disabled = true;
  btn.textContent = 'Submitting...';

  const isSatisfied = document.querySelector('input[name="fbSatisfied"]:checked').value === 'true';
  const comment = document.getElementById('fbComment').value.trim();

  try {
    const res = await window.NIRVAAH.Complaints.submitFeedback(id, {
      rating: currentRating,
      isSatisfied,
      comment
    });
    if (res.success) {
      showToast('Thank You!', 'Your feedback helps us improve.', 'success');
      const container = document.getElementById('feedbackContainer');
      renderFeedbackSummary(container, res.feedback);
    }
  } catch (e) {
    showToast('Error', e.message || 'Failed to submit feedback.', 'error');
    btn.disabled = false;
    btn.textContent = 'Submit Feedback';
  }
}

loadWithEvidence();
</script>
</body></html>